<%- include('../layout/header', { currentPage: 'jobs' }) %>

<section class="page-hero page-hero-sm" style="padding-top: calc(var(--navbar-h) + 2rem); padding-bottom: 2rem; margin-bottom: 3rem; border-bottom: 1px solid rgba(255, 255, 255, 0.06); background: rgba(4, 13, 26, 0.2);">
  <div class="page-hero-bg"></div>
  <div class="container" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1.5rem; position: relative; z-index: 10;">
    <div>
      <h1 class="page-hero-title" style="margin: 0; font-size: 2rem; font-weight: 700; color: #fff; letter-spacing: -0.01em;">Kariyer Fırsatları</h1>
      <p style="margin: 0.35rem 0 0 0; color: var(--text-muted); font-size: 0.95rem;">AIESEC İstanbul mezunları arasında iş, staj ve iş birliği ilanları.</p>
    </div>
    <div>
      <button onclick="openJobModal()" class="btn btn-primary" style="display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.65rem 1.3rem; border-radius: 8px; font-weight: 600; font-size: 0.9rem; cursor: pointer;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Yeni İlan Yayınla
      </button>
    </div>
  </div>
</section>

<main class="container" style="max-width: 900px; margin: 0 auto 5rem auto; padding: 0 1rem;">

  <!-- Listings -->
  <% if (jobs.length === 0) { %>
    <div class="empty-state" style="background: var(--surface); border: 1px solid var(--border); padding: 5rem 2rem; border-radius: 16px; text-align: center;">
      <div class="empty-icon" style="font-size: 3.5rem; margin-bottom: 1rem;">💼</div>
      <h3 style="font-size: 1.4rem; font-weight: 600; color: #fff; margin-bottom: 0.5rem;">Henüz ilan yayınlanmamış</h3>
      <p style="color: var(--text-muted); max-width: 450px; margin: 0 auto; line-height: 1.6;">Topluluğa özel ilk kariyer veya staj fırsatını siz paylaşın!</p>
    </div>
  <% } else { %>
    <div style="display: flex; flex-direction: column; gap: 2rem;">
      <% jobs.forEach(job => { %>
        <div class="profile-card" style="padding: 2.5rem; border-radius: 16px; background: var(--surface); border: 1px solid var(--border); transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 4px 20px rgba(0,0,0,0.15); display: flex; flex-direction: column; gap: 1.5rem;">
          
          <!-- Creator header -->
          <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(255,255,255,0.06); padding-bottom: 1rem;">
            <div style="display: flex; gap: 0.75rem; align-items: center;">
              <img src="<%= job.user_photo || '/images/default-avatar.svg' %>" alt="<%= job.user_name %>" style="width: 42px; height: 42px; border-radius: 50%; object-fit: cover; border: 1px solid var(--border);">
              <div>
                <h4 style="font-size: 0.95rem; font-weight: 600; color: var(--white); margin: 0;"><%= job.user_name %></h4>
                <span style="font-size: 0.8rem; color: var(--text-muted);">
                  <%= new Date(job.created_at).toLocaleDateString('tr-TR', { day: '2-digit', month: 'long', year: 'numeric' }) %>
                </span>
              </div>
            </div>
            <% if (currentUser && (currentUser.role === 'admin' || job.user_id === currentUser.id)) { %>
              <form action="/jobs/delete/<%= job.id %>" method="POST" style="margin: 0;" onsubmit="return confirm('Bu ilanı silmek istediğinizden emin misiniz?')">
                <button type="submit" class="btn btn-delete btn-xs" style="padding: 0.45rem 0.9rem; font-size: 0.75rem; border-radius: 6px; background: rgba(239, 68, 68, 0.08); border-color: rgba(239, 68, 68, 0.3); color: #f87171;">🗑 Sil</button>
              </form>
            <% } %>
          </div>

          <!-- Job Details -->
          <div>
            <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 0.5rem; flex-wrap: wrap;">
              <h3 style="font-size: 1.5rem; font-weight: 700; color: var(--white); margin: 0;"><%= job.title %></h3>
              <span style="font-size: 0.8rem; background: rgba(3, 126, 243, 0.1); color: var(--primary); padding: 0.3rem 0.8rem; border-radius: 20px; font-weight: 600; border: 1px solid rgba(3, 126, 243, 0.2);">
                <%= job.type %>
              </span>
            </div>
            <h4 style="font-size: 1.1rem; font-weight: 600; color: var(--primary); margin: 0 0 1.25rem 0;"><%= job.company %></h4>
            
            <% if (job.location) { %>
              <div style="display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; color: var(--text-muted); background: rgba(255,255,255,0.03); padding: 0.3rem 0.75rem; border-radius: 8px; margin-bottom: 1.25rem; border: 1px solid var(--border);">
                📍 <%= job.location %>
              </div>
            <% } %>

            <p style="color: var(--text-lighter); font-size: 1rem; line-height: 1.7; white-space: pre-line; margin: 0;"><%= job.description %></p>
          </div>

          <!-- Apply Action -->
          <% if (job.link) { %>
            <div style="margin-top: 0.5rem; border-top: 1px solid rgba(255,255,255,0.06); padding-top: 1.25rem;">
              <a href="<%= job.link %>" target="_blank" rel="noopener" class="btn btn-primary" style="display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.6rem 1.2rem; border-radius: 8px; font-weight: 600;">
                Başvur / İletişime Geç 
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/></svg>
              </a>
            </div>
          <% } %>

        </div>
      <% }) %>
    </div>
  <% } %>
</main>

<!-- Glassmorphic Modal Form -->
<div id="jobModal" style="display: none; position: fixed; inset: 0; background: rgba(4, 13, 26, 0.7); backdrop-filter: blur(10px); z-index: 1000; align-items: center; justify-content: center; padding: 1.5rem; opacity: 0; transition: opacity 0.3s ease;">
  <div style="background: var(--surface); border: 1px solid var(--border); width: 100%; max-width: 600px; border-radius: 20px; padding: 2.5rem; position: relative; box-shadow: 0 20px 40px rgba(0,0,0,0.5); transform: translateY(-20px); transition: transform 0.3s ease;" id="jobModalContainer">
    
    <!-- Close button -->
    <button onclick="closeJobModal()" style="position: absolute; right: 1.5rem; top: 1.5rem; background: none; border: none; color: var(--text-muted); font-size: 1.75rem; cursor: pointer; line-height: 1;">&times;</button>
    
    <h3 style="font-size: 1.4rem; font-weight: 700; color: #fff; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
      💼 Yeni İlan Yayınla
    </h3>
    <p style="font-size: 0.875rem; color: var(--text-muted); margin-bottom: 2rem;">Topluluk mezunlarına sunmak istediğiniz fırsatın tüm detaylarını girin.</p>

    <form action="/jobs" method="POST" style="display: flex; flex-direction: column; gap: 1.25rem;">
      <div class="form-group" style="margin: 0;">
        <label for="title" class="form-label">Pozisyon Başlığı *</label>
        <input type="text" id="title" name="title" class="form-input" required placeholder="Örn: Senior Product Manager">
      </div>

      <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 0;">
        <div class="form-group" style="margin: 0;">
          <label for="company" class="form-label">Şirket *</label>
          <input type="text" id="company" name="company" class="form-input" required placeholder="Örn: Google">
        </div>
        <div class="form-group" style="margin: 0;">
          <label for="location" class="form-label">Konum / Lokasyon</label>
          <input type="text" id="location" name="location" class="form-input" placeholder="Örn: Dublin (Hybrid)">
        </div>
      </div>

      <div class="form-group" style="margin: 0;">
        <label for="type" class="form-label">Çalışma Türü *</label>
        <select id="type" name="type" class="form-input">
          <option value="Tam Zamanlı">Tam Zamanlı</option>
          <option value="Yarı Zamanlı">Yarı Zamanlı</option>
          <option value="Staj / Intern">Staj / Intern</option>
          <option value="Proje Bazlı / Freelance">Proje Bazlı / Freelance</option>
          <option value="İş Birliği / Ortaklık">İş Birliği / Ortaklık</option>
        </select>
      </div>

      <div class="form-group" style="margin: 0;">
        <label for="description" class="form-label">İş Açıklaması *</label>
        <textarea id="description" name="description" class="form-input" rows="5" required placeholder="Aranan kriterler, yetkinlikler ve başvuru bilgileri..."></textarea>
      </div>

      <div class="form-group" style="margin: 0;">
        <label for="link" class="form-label">Başvuru Linki veya E-posta (Opsiyonel)</label>
        <input type="text" id="link" name="link" class="form-input" placeholder="https://... veya mailto:hr@company.com">
      </div>

      <button type="submit" class="btn btn-primary" style="padding: 0.85rem; font-weight: 600; margin-top: 1rem; border-radius: 10px;">İlanı Yayınla</button>
    </form>
  </div>
</div>

<script>
  function openJobModal() {
    const modal = document.getElementById('jobModal');
    const container = document.getElementById('jobModalContainer');
    modal.style.display = 'flex';
    setTimeout(() => {
      modal.style.opacity = '1';
      container.style.transform = 'translateY(0)';
    }, 10);
  }

  function closeJobModal() {
    const modal = document.getElementById('jobModal');
    const container = document.getElementById('jobModalContainer');
    modal.style.opacity = '0';
    container.style.transform = 'translateY(-20px)';
    setTimeout(() => {
      modal.style.display = 'none';
    }, 300);
  }
</script>

<%- include('../layout/footer') %>
