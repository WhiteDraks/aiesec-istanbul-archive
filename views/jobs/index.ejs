<%- include('../layout/header', { currentPage: 'jobs' }) %>

<section class="page-hero page-hero-sm">
  <div class="page-hero-bg"></div>
  <div class="container">
    <div class="breadcrumb">
      <a href="/">Ana Sayfa</a>
      <span>›</span>
      <span>Kariyer Panosu</span>
    </div>
    <h1 class="page-hero-title">Kariyer Fırsatları</h1>
    <p class="page-hero-sub">AIESEC İstanbul mezunları arasında iş, staj ve iş birliği ilanları.</p>
  </div>
</section>

<main class="container" style="margin-top: 3rem; margin-bottom: 5rem;">
  <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2.5rem; align-items: start;">
    
    <!-- Left: Job Listings -->
    <div>
      <h2 style="font-size: 1.5rem; font-weight: 700; color: #fff; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
        💼 Aktif İlanlar 
        <span style="font-size: 0.9rem; background: var(--primary); padding: 0.2rem 0.6rem; border-radius: 20px; font-weight: 500;"><%= jobs.length %></span>
      </h2>

      <% if (jobs.length === 0) { %>
        <div class="empty-state" style="background: var(--surface); border: 1px solid var(--border); padding: 4rem 2rem; border-radius: 16px; text-align: center;">
          <div class="empty-icon" style="font-size: 3rem; margin-bottom: 1rem;">💼</div>
          <h3 style="font-size: 1.25rem; font-weight: 600; color: #fff; margin-bottom: 0.5rem;">Henüz ilan yayınlanmamış</h3>
          <p style="color: var(--text-muted); max-width: 400px; margin: 0 auto;">İlk kariyer veya staj fırsatını sağ taraftaki formu kullanarak siz paylaşın!</p>
        </div>
      <% } else { %>
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
          <% jobs.forEach(job => { %>
            <div class="profile-card" style="padding: 2rem; display: flex; flex-direction: column; gap: 1.25rem; position: relative;">
              
              <!-- Creator Info & Delete Button -->
              <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
                <div style="display: flex; gap: 0.75rem; align-items: center;">
                  <div style="width: 40px; height: 40px; border-radius: 50%; overflow: hidden; border: 1px solid var(--border); background: var(--background); display: flex; align-items: center; justify-content: center;">
                    <img src="<%= job.user_photo || '/images/default-avatar.svg' %>" alt="<%= job.user_name %>" style="width: 100%; height: 100%; object-fit: cover;">
                  </div>
                  <div>
                    <h4 style="font-size: 0.9rem; font-weight: 600; color: #fff; margin: 0;"><%= job.user_name %></h4>
                    <span style="font-size: 0.75rem; color: var(--text-muted);">
                      <%= new Date(job.created_at).toLocaleDateString('tr-TR', { day: '2-digit', month: 'short', year: 'numeric' }) %> tarihinde paylaştı
                    </span>
                  </div>
                </div>

                <% if (currentUser && (currentUser.role === 'admin' || job.user_id === currentUser.id)) { %>
                  <form action="/jobs/delete/<%= job.id %>" method="POST" style="margin: 0;" onsubmit="return confirm('Bu ilanı silmek istediğinizden emin misiniz?')">
                    <button type="submit" class="btn btn-delete btn-xs" style="padding: 0.4rem 0.8rem; font-size: 0.75rem;">🗑 Sil</button>
                  </form>
                <% } %>
              </div>

              <!-- Job Info -->
              <div>
                <h3 style="font-size: 1.35rem; font-weight: 700; color: #fff; margin-bottom: 0.25rem;"><%= job.title %></h3>
                <h4 style="font-size: 1rem; font-weight: 600; color: var(--primary); margin-bottom: 0.75rem;"><%= job.company %></h4>
                
                <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem;">
                  <span style="font-size: 0.8rem; background: rgba(3, 126, 243, 0.1); color: var(--primary); padding: 0.25rem 0.75rem; border-radius: 20px; font-weight: 500;">
                    📁 <%= job.type %>
                  </span>
                  <% if (job.location) { %>
                    <span style="font-size: 0.8rem; background: rgba(255, 255, 255, 0.05); color: var(--text-muted); padding: 0.25rem 0.75rem; border-radius: 20px;">
                      📍 <%= job.location %>
                    </span>
                  <% } %>
                </div>

                <p style="color: var(--text-muted); font-size: 0.925rem; line-height: 1.6; white-space: pre-line;"><%= job.description %></p>
              </div>

              <!-- Call to Action Link -->
              <% if (job.link) { %>
                <div style="margin-top: 0.5rem;">
                  <a href="<%= job.link %>" target="_blank" rel="noopener" class="btn btn-primary btn-sm" style="display: inline-flex; align-items: center; gap: 0.35rem;">
                    Başvur / Detayları Gör 
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/></svg>
                  </a>
                </div>
              <% } %>

            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Right: Add Job Form -->
    <div class="profile-card" style="padding: 2.25rem; position: sticky; top: 6rem;">
      <h3 style="font-size: 1.2rem; font-weight: 700; color: #fff; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.4rem;">
        ➕ Yeni İlan Yayınla
      </h3>
      <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 1.5rem;">Mezunlarımıza sunmak istediğiniz fırsatın detaylarını girin.</p>

      <form action="/jobs" method="POST" style="display: flex; flex-direction: column; gap: 1.25rem;">
        <div class="form-group" style="margin: 0;">
          <label for="title" class="form-label" style="font-size: 0.775rem;">Pozisyon Başlığı *</label>
          <input type="text" id="title" name="title" class="form-input" required placeholder="Örn: Senior Frontend Developer">
        </div>

        <div class="form-group" style="margin: 0;">
          <label for="company" class="form-label" style="font-size: 0.775rem;">Şirket / Organizasyon *</label>
          <input type="text" id="company" name="company" class="form-input" required placeholder="Örn: Getir">
        </div>

        <div class="form-group" style="margin: 0;">
          <label for="location" class="form-label" style="font-size: 0.775rem;">Konum (Şehir / Hibrit / Uzaktan)</label>
          <input type="text" id="location" name="location" class="form-input" placeholder="Örn: İstanbul (Hybrid)">
        </div>

        <div class="form-group" style="margin: 0;">
          <label for="type" class="form-label" style="font-size: 0.775rem;">Çalışma Türü *</label>
          <select id="type" name="type" class="form-input">
            <option value="Tam Zamanlı">Tam Zamanlı</option>
            <option value="Yarı Zamanlı">Yarı Zamanlı</option>
            <option value="Staj / Intern">Staj / Intern</option>
            <option value="Proje Bazlı / Freelance">Proje Bazlı / Freelance</option>
            <option value="İş Birliği / Ortaklık">İş Birliği / Ortaklık</option>
          </select>
        </div>

        <div class="form-group" style="margin: 0;">
          <label for="description" class="form-label" style="font-size: 0.775rem;">Detaylı Açıklama *</label>
          <textarea id="description" name="description" class="form-input" rows="5" required placeholder="Aranan nitelikler, iş tanımı, başvuru yöntemi..."></textarea>
        </div>

        <div class="form-group" style="margin: 0;">
          <label for="link" class="form-label" style="font-size: 0.775rem;">Başvuru Linki veya E-posta (Opsiyonel)</label>
          <input type="text" id="link" name="link" class="form-input" placeholder="https://... veya mailto:hr@company.com">
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.75rem; font-weight: 600; margin-top: 0.5rem;">İlanı Yayınla</button>
      </form>
    </div>

  </div>
</main>

<%- include('../layout/footer') %>
