<%- include('../layout/header', { currentPage: 'events' }) %>

<section class="page-hero page-hero-sm" style="padding-bottom: 2rem; margin-bottom: 3rem;">
  <div class="page-hero-bg"></div>
  <div class="container">
    
    <!-- Glassmorphic Dashboard Header Card -->
    <div style="background: rgba(17, 24, 39, 0.45); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 20px; padding: 2.25rem; backdrop-filter: blur(12px); box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1.5rem; margin-top: 1rem;">
      
      <!-- Left Info -->
      <div>
        <div class="breadcrumb" style="margin-bottom: 0.5rem; opacity: 0.85;">
          <a href="/">Ana Sayfa</a>
          <span style="margin: 0 0.4rem;">›</span>
          <span style="color: var(--primary); font-weight: 500;">Etkinlikler</span>
        </div>
        <h1 class="page-hero-title" style="margin: 0; font-size: 2.2rem; background: linear-gradient(135deg, #fff, #9ca3af); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Mezun Buluşmaları</h1>
        <p style="margin: 0.5rem 0 0 0; color: var(--text-muted); font-size: 0.95rem; max-width: 480px;">AIESEC İstanbul mezun buluşmaları, webinarlar ve sosyal buluşmalar.</p>
      </div>

      <!-- Right Controls / Stats & Action -->
      <div style="display: flex; gap: 1.25rem; align-items: center; flex-wrap: wrap;">
        
        <!-- Premium Mini Stat Card -->
        <div style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.06); padding: 0.6rem 1.25rem; border-radius: 12px; text-align: center; min-width: 100px;">
          <div style="font-size: 0.775rem; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.5px; font-weight: 600;">Etkinlik</div>
          <div style="font-size: 1.35rem; font-weight: 800; color: var(--primary); margin-top: 0.15rem;"><%= events.length %></div>
        </div>

        <button onclick="openEventModal()" class="btn btn-primary" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.8rem 1.6rem; border-radius: 12px; font-weight: 700; box-shadow: 0 4px 20px rgba(3, 126, 243, 0.4); border: 1px solid rgba(255,255,255,0.1); cursor: pointer; transition: transform 0.2s;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Yeni Buluşma Düzenle
        </button>

      </div>
    </div>

  </div>
</section>

<main class="container" style="max-width: 900px; margin: 0 auto 5rem auto; padding: 0 1rem;">

  <!-- Listings -->
  <% if (events.length === 0) { %>
    <div class="empty-state" style="background: var(--surface); border: 1px solid var(--border); padding: 5rem 2rem; border-radius: 16px; text-align: center;">
      <div class="empty-icon" style="font-size: 3.5rem; margin-bottom: 1rem;">📅</div>
      <h3 style="font-size: 1.4rem; font-weight: 600; color: #fff; margin-bottom: 0.5rem;">Henüz etkinlik planlanmamış</h3>
      <p style="color: var(--text-muted); max-width: 450px; margin: 0 auto; line-height: 1.6;">Topluluğa özel ilk mezun buluşmasını veya online etkinliği siz planlayın!</p>
    </div>
  <% } else { %>
    <div style="display: flex; flex-direction: column; gap: 2rem;">
      <% events.forEach(event => { %>
        <div class="profile-card" style="padding: 2.5rem; border-radius: 16px; background: var(--surface); border: 1px solid var(--border); transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 4px 20px rgba(0,0,0,0.15); display: flex; gap: 2rem; flex-wrap: wrap; align-items: flex-start;">
          
          <!-- Date badge -->
          <div style="flex-shrink: 0; width: 85px; height: 90px; border-radius: 14px; background: rgba(3, 126, 243, 0.08); border: 1px solid rgba(3, 126, 243, 0.25); display: flex; flex-direction: column; align-items: center; justify-content: center; color: #fff; box-shadow: 0 4px 10px rgba(0,0,0,0.2);">
            <span style="font-size: 1.8rem; font-weight: 800; line-height: 1; color: var(--primary);">
              <%= new Date(event.event_date).toLocaleDateString('tr-TR', { day: '2-digit' }) %>
            </span>
            <span style="font-size: 0.8rem; text-transform: uppercase; font-weight: 600; margin-top: 0.35rem; color: var(--text-lighter); letter-spacing: 0.5px;">
              <%= new Date(event.event_date).toLocaleDateString('tr-TR', { month: 'short' }) %>
            </span>
          </div>

          <!-- Content Details -->
          <div style="flex: 1; min-width: 250px; display: flex; flex-direction: column; gap: 1rem;">
            
            <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap;">
              <div>
                <h3 style="font-size: 1.45rem; font-weight: 700; color: #fff; margin: 0;"><%= event.title %></h3>
                <div style="font-size: 0.85rem; color: var(--text-muted); display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 0.35rem;">
                  <span>🕒 <%= new Date(event.event_date).toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' }) %></span>
                  <span>📍 <%= event.location %></span>
                  <span>👤 Düzenleyen: <%= event.creator_name %></span>
                </div>
              </div>
              <% if (currentUser && (currentUser.role === 'admin' || event.created_by === currentUser.id)) { %>
                <form action="/events/delete/<%= event.id %>" method="POST" style="margin: 0;" onsubmit="return confirm('Bu etkinliği silmek istediğinizden emin misiniz?')">
                  <button type="submit" class="btn btn-delete btn-xs" style="padding: 0.45rem 0.9rem; font-size: 0.75rem; border-radius: 6px; background: rgba(239, 68, 68, 0.08); border-color: rgba(239, 68, 68, 0.3); color: #f87171;">🗑 Sil</button>
                </form>
              <% } %>
            </div>

            <p style="color: var(--text-lighter); font-size: 0.975rem; line-height: 1.7; white-space: pre-line; margin: 0;"><%= event.description %></p>

            <!-- Attendee count and avatars -->
            <% if (event.attendees && event.attendees.length > 0) { %>
              <div style="border-top: 1px dashed rgba(255,255,255,0.08); padding-top: 1.25rem; margin-top: 0.5rem;">
                <h4 style="font-size: 0.825rem; font-weight: 600; color: #fff; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.35rem;">
                  👥 Katılacak Üyelerimiz (<%= event.attendee_count %>):
                </h4>
                <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;">
                  <% event.attendees.forEach(att => { %>
                    <div style="display: inline-flex; align-items: center; background: rgba(255,255,255,0.03); border: 1px solid var(--border); padding: 0.3rem 0.65rem; border-radius: 20px; gap: 0.4rem; font-size: 0.775rem; color: var(--text-lighter); transition: transform 0.2s;">
                      <img src="<%= att.photo || '/images/default-avatar.svg' %>" alt="<%= att.name %>" style="width: 20px; height: 20px; border-radius: 50%; object-fit: cover;">
                      <span><%= att.name %></span>
                    </div>
                  <% }) %>
                </div>
              </div>
            <% } %>

            <!-- Action buttons -->
            <div style="margin-top: 0.75rem; display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; border-top: 1px solid rgba(255,255,255,0.06); padding-top: 1.25rem;">
              <% if (event.attending) { %>
                <form action="/events/<%= event.id %>/leave" method="POST" style="margin: 0;">
                  <button type="submit" class="btn btn-outline btn-sm" style="border-color: #ff4d4f; color: #ff4d4f; background: rgba(255,77,79,0.05); border-radius: 8px;">Katılmaktan Vazgeç ❌</button>
                </form>
              <% } else { %>
                <form action="/events/<%= event.id %>/attend" method="POST" style="margin: 0;">
                  <button type="submit" class="btn btn-primary btn-sm" style="border-radius: 8px;">Buluşmaya Katıl 🎉</button>
                </form>
              <% } %>
              
              <% if (event.link) { %>
                <a href="<%= event.link %>" target="_blank" rel="noopener" class="btn btn-ghost btn-sm" style="font-size: 0.85rem; border-radius: 8px; display: inline-flex; align-items: center; gap: 0.25rem;">
                  Katılım Linki / Harita 🔗
                </a>
              <% } %>
            </div>

          </div>

        </div>
      <% }) %>
    </div>
  <% } %>
</main>

<!-- Glassmorphic Modal Form -->
<div id="eventModal" style="display: none; position: fixed; inset: 0; background: rgba(4, 13, 26, 0.7); backdrop-filter: blur(10px); z-index: 1000; align-items: center; justify-content: center; padding: 1.5rem; opacity: 0; transition: opacity 0.3s ease;">
  <div style="background: var(--surface); border: 1px solid var(--border); width: 100%; max-width: 600px; border-radius: 20px; padding: 2.5rem; position: relative; box-shadow: 0 20px 40px rgba(0,0,0,0.5); transform: translateY(-20px); transition: transform 0.3s ease;" id="eventModalContainer">
    
    <!-- Close button -->
    <button onclick="closeEventModal()" style="position: absolute; right: 1.5rem; top: 1.5rem; background: none; border: none; color: var(--text-muted); font-size: 1.75rem; cursor: pointer; line-height: 1;">&times;</button>
    
    <h3 style="font-size: 1.4rem; font-weight: 700; color: #fff; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
      📅 Yeni Buluşma / Etkinlik Oluştur
    </h3>
    <p style="font-size: 0.875rem; color: var(--text-muted); margin-bottom: 2rem;">AIESEC İstanbul mezunları için planladığınız buluşmanın tüm detaylarını girin.</p>

    <form action="/events" method="POST" style="display: flex; flex-direction: column; gap: 1.25rem;">
      <div class="form-group" style="margin: 0;">
        <label for="title" class="form-label">Etkinlik Başlığı *</label>
        <input type="text" id="title" name="title" class="form-input" required placeholder="Örn: AIESEC İstanbul Yaz Pikniği">
      </div>

      <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 0;">
        <div class="form-group" style="margin: 0;">
          <label for="event_date" class="form-label">Tarih & Saat *</label>
          <input type="datetime-local" id="event_date" name="event_date" class="form-input" required>
        </div>
        <div class="form-group" style="margin: 0;">
          <label for="location" class="form-label">Mekan / Konum *</label>
          <input type="text" id="location" name="location" class="form-input" required placeholder="Örn: Google Meet / Belgrad Ormanı">
        </div>
      </div>

      <div class="form-group" style="margin: 0;">
        <label for="description" class="form-label">Etkinlik Açıklaması *</label>
        <textarea id="description" name="description" class="form-input" rows="4" required placeholder="Buluşma detayları, ortak planlar..."></textarea>
      </div>

      <div class="form-group" style="margin: 0;">
        <label for="link" class="form-label">Online Görüşme / Konum Linki (Opsiyonel)</label>
        <input type="url" id="link" name="link" class="form-input" placeholder="https://meet.google.com/... veya harita adresi">
      </div>

      <button type="submit" class="btn btn-primary" style="padding: 0.85rem; font-weight: 600; margin-top: 1rem; border-radius: 10px;">Etkinliği Oluştur</button>
    </form>
  </div>
</div>

<script>
  function openEventModal() {
    const modal = document.getElementById('eventModal');
    const container = document.getElementById('eventModalContainer');
    modal.style.display = 'flex';
    setTimeout(() => {
      modal.style.opacity = '1';
      container.style.transform = 'translateY(0)';
    }, 10);
  }

  function closeEventModal() {
    const modal = document.getElementById('eventModal');
    const container = document.getElementById('eventModalContainer');
    modal.style.opacity = '0';
    container.style.transform = 'translateY(-20px)';
    setTimeout(() => {
      modal.style.display = 'none';
    }, 300);
  }
</script>

<%- include('../layout/footer') %>
