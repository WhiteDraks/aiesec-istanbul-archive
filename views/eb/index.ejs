<%- include('../layout/header', { currentPage: 'eb' }) %>

<section class="page-hero page-hero-sm">
  <div class="page-hero-bg"></div>
  <div class="container">
    <div class="breadcrumb">
      <a href="/">Ana Sayfa</a>
      <span>›</span>
      <span>EB Takımları</span>
    </div>
    <h1 class="page-hero-title">Executive Board Takımları</h1>
    <p class="page-hero-sub">AIESEC İstanbul'un geçmiş ve mevcut dönem liderlik takımları</p>
  </div>
</section>

<section class="section">
  <div class="container">

    <!-- Years Checklist Filter Bar -->
    <style>
      .filter-scroll-container {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        align-items: center;
        max-height: 140px;
        overflow-y: auto;
        padding: 0.75rem;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.01);
        border: 1px solid var(--border);
      }
      .filter-scroll-container::-webkit-scrollbar {
        width: 6px;
      }
      .filter-scroll-container::-webkit-scrollbar-track {
        background: transparent;
      }
      .filter-scroll-container::-webkit-scrollbar-thumb {
        background: var(--border);
        border-radius: 3px;
      }
      .filter-scroll-container::-webkit-scrollbar-thumb:hover {
        background: var(--primary);
      }
    </style>
    <div class="filter-bar" style="background: var(--surface); border: 1px solid var(--border); padding: 1.5rem; border-radius: 16px; margin-bottom: 2.5rem; box-shadow: 0 4px 30px rgba(0, 0, 0, 0.03);">
      <form action="/eb" method="GET" style="display: flex; flex-direction: column; gap: 1rem; width: 100%;">
        <span style="font-size: 0.85rem; font-weight: 600; color: var(--text-lighter);">Gösterilecek Yılları Seçin:</span>
        <div class="filter-scroll-container">
          <% availableYears.forEach(year => { %>
            <label class="btn btn-outline" style="display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; padding: 0.4rem 0.8rem; border-radius: 20px; font-weight: 500; cursor: pointer; color: var(--text); border-color: var(--border); background: var(--surface);">
              <input type="checkbox" name="years[]" value="<%= year %>" <%= (typeof selectedYears !== 'undefined' && selectedYears.includes(year)) ? 'checked' : '' %> style="cursor: pointer; width: 15px; height: 15px; border-radius: 3px; accent-color: var(--primary);">
              <%= year %>
            </label>
          <% }) %>
        </div>
        <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
          <button type="submit" class="btn btn-primary btn-sm" style="padding: 0.5rem 1.25rem; font-size: 0.85rem; border-radius: 8px; font-weight: 600;">Filtrele 🔍</button>
          <% if (typeof selectedYears !== 'undefined' && selectedYears.length > 0) { %>
            <a href="/eb" class="btn btn-outline btn-sm" style="padding: 0.5rem 1.25rem; font-size: 0.85rem; border-radius: 8px; font-weight: 600;">Temizle</a>
          <% } %>
        </div>
      </form>
    </div>

    <% if (!currentUser || !isApproved) { %>
      <div class="access-notice">
        <div class="access-notice-icon">🔒</div>
        <div>
          <h3>Detaylı Bilgiler için Giriş Gerekli</h3>
          <p>EB takım detaylarını ve üye bilgilerini görmek için kayıt olup admin onayı almanız gerekmektedir.</p>
          <div class="access-notice-actions">
            <a href="/auth/login" class="btn btn-primary btn-sm">Giriş Yap</a>
            <a href="/auth/register" class="btn btn-outline btn-sm">Kayıt Ol</a>
          </div>
        </div>
      </div>
    <% } %>

    <% if (teams && teams.length > 0) { %>
      <div class="years-grid">
        <% teams.forEach((team, i) => { %>
          <article class="year-card" style="--card-delay: <%= i * 0.08 %>s">
            <div class="year-card-cover">
              <img
                src="<%= team.cover_image || '/images/default-cover.jpg' %>"
                alt="<%= team.year %> EB Kapak"
                loading="lazy"
              />
              <div class="year-card-overlay"></div>
            </div>
            <div class="year-card-body">
              <div class="year-badge"><%= team.year %></div>
              <h2 class="year-card-title"><%= team.title %></h2>
              <% if (team.description) { %>
                <p class="year-card-desc"><%= team.description.substring(0, 120) %><%= team.description.length > 120 ? '...' : '' %></p>
              <% } %>
              <p class="year-card-members-count" style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle;"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <%= team.member_count %> üye
              </p>
              <div class="year-card-footer">
                <% if (currentUser && isApproved) { %>
                  <a href="/eb/<%= encodeURIComponent(team.year) %>" class="btn btn-primary">Dönemi İncele →</a>
                <% } else { %>
                  <a href="/auth/login?redirect=/eb/<%= encodeURIComponent(team.year) %>" class="btn btn-outline">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    Giriş Yap
                  </a>
                <% } %>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <div class="empty-icon">📋</div>
        <h3>Henüz EB dönemi yok</h3>
        <p>Üyeler profil sayfalarından dönemlerini girdikçe burası otomatik dolacak.</p>
        <% if (currentUser) { %>
          <a href="/profile" class="btn btn-primary" style="margin-top: 1rem;">Profilimi Güncelle</a>
        <% } %>
      </div>
    <% } %>
  </div>
</section>

<%- include('../layout/footer') %>
