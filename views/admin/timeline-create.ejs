<%- include('../layout/header', { currentPage: 'admin' }) %>

<section class="page-hero page-hero-sm page-hero-admin">
  <div class="page-hero-bg"></div>
  <div class="container">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
      <div>
        <h1 class="page-hero-title">➕ Yeni Kilometre Taşı</h1>
        <p class="page-hero-sub">Tarih şeridine yeni bir dönüm noktası ekleyin.</p>
      </div>
      <div>
        <a href="/admin/timeline" class="btn btn-outline">◀ İptal ve Geri Dön</a>
      </div>
    </div>
  </div>
</section>

<section class="section section-admin">
  <div class="container">
    <div class="admin-panel" style="max-width: 800px; margin: 0 auto;">
      <form action="/admin/timeline/create" method="POST" enctype="multipart/form-data" class="admin-form">
        
        <div class="form-group">
          <label class="form-label">Yıl</label>
          <input type="number" name="year" class="form-input" required placeholder="Örn: 2012">
        </div>

        <div class="form-group">
          <label class="form-label">Başlık</label>
          <input type="text" name="title" class="form-input" required placeholder="Örn: İstanbul Asya LC Kuruldu">
        </div>

        <div class="form-group">
          <label class="form-label">Açıklama</label>
          <textarea name="description" class="form-input" rows="4" required placeholder="Bu dönüm noktasının önemini kısaca açıklayın..."></textarea>
        </div>

        <div class="form-group">
          <label class="form-label">Görsel (Opsiyonel)</label>
          <input type="file" name="image" class="form-input" accept="image/*">
          <p class="form-hint" style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.5rem;">Bu dönemi yansıtan temsili bir fotoğraf ekleyebilirsiniz.</p>
        </div>

        <div style="margin-top: 2rem;">
          <button type="submit" class="btn btn-primary btn-block">Kilometre Taşını Kaydet</button>
        </div>
      </form>
    </div>
  </div>
</section>

<%- include('../layout/footer') %>
