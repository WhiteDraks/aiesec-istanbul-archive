<%- include('../layout/header', { currentPage: 'admin' }) %>

<section class="page-hero page-hero-sm page-hero-admin">
  <div class="page-hero-bg"></div>
  <div class="container">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center;">
      <div>
        <h1 class="page-hero-title">Admin Paneli</h1>
        <p class="page-hero-sub">AIESEC İstanbul Alumni Archive Yönetimi</p>
      </div>
      <a href="/admin/eb" class="btn btn-primary">EB Takımlarını Yönet</a>
    </div>
  </div>
</section>

<section class="section section-admin">
  <div class="container">

    <!-- Stats Row -->
    <div class="admin-stats">
      <div class="admin-stat admin-stat-pending">
        <span class="admin-stat-num"><%= stats.pending %></span>
        <span class="admin-stat-label">Bekleyen</span>
      </div>
      <div class="admin-stat admin-stat-approved">
        <span class="admin-stat-num"><%= stats.approved %></span>
        <span class="admin-stat-label">Onaylı</span>
      </div>
      <div class="admin-stat admin-stat-rejected">
        <span class="admin-stat-num"><%= stats.rejected %></span>
        <span class="admin-stat-label">Reddedilen</span>
      </div>
      <div class="admin-stat admin-stat-total">
        <span class="admin-stat-num"><%= stats.total %></span>
        <span class="admin-stat-label">Toplam Üye</span>
      </div>
    </div>

    <!-- Tabs -->
    <div class="admin-tabs" role="tablist">
      <button class="admin-tab active" data-tab="pending" role="tab" aria-selected="true">
        Bekleyenler
        <% if (stats.pending > 0) { %><span class="tab-badge tab-badge-pending"><%= stats.pending %></span><% } %>
      </button>
      <button class="admin-tab" data-tab="approved" role="tab" aria-selected="false">
        Onaylılar
        <span class="tab-badge tab-badge-approved"><%= stats.approved %></span>
      </button>
      <button class="admin-tab" data-tab="rejected" role="tab" aria-selected="false">
        Reddedilenler
        <span class="tab-badge tab-badge-rejected"><%= stats.rejected %></span>
      </button>
      <button class="admin-tab" data-tab="feedbacks" role="tab" aria-selected="false">
        Geri Bildirimler 💬
        <% if (feedbacks.length > 0) { %><span class="tab-badge" style="background: var(--primary);"><%= feedbacks.length %></span><% } %>
      </button>
    </div>

    <!-- ── Pending Users ── -->
    <div class="admin-panel" id="tab-pending" role="tabpanel">
      <% if (pendingUsers.length === 0) { %>
        <div class="empty-state empty-state-sm">
          <div class="empty-icon">✅</div>
          <h3>Bekleyen kayıt yok</h3>
          <p>Tüm kayıtlar işlendi.</p>
        </div>
      <% } else { %>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Ad Soyad</th>
                <th>E-posta</th>
                <th>Üniversite</th>
                <th>EB Dönemi</th>
                <th>Kayıt Tarihi</th>
                <th>İşlem</th>
              </tr>
            </thead>
            <tbody>
              <% pendingUsers.forEach(u => { %>
                <tr class="admin-row">
                  <td class="user-name-cell">
                    <div class="user-avatar-mini"><%= u.name.charAt(0).toUpperCase() %></div>
                    <span><%= u.name %></span>
                  </td>
                  <td><a href="mailto:<%= u.email %>" class="table-link"><%= u.email %></a></td>
                  <td><%= u.school || '—' %></td>
                  <td><%= u.eb_year || '—' %></td>
                  <td class="date-cell">
                    <%= new Date(u.created_at).toLocaleDateString('tr-TR', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                  </td>
                  <td class="action-cell">
                    <a href="/admin/user/<%= u.id %>/edit" class="btn btn-outline btn-xs">✎ Düzenle</a>
                    <form action="/admin/approve/<%= u.id %>" method="POST" style="display:inline">
                      <button type="submit" class="btn btn-approve btn-xs">✓ Onayla</button>
                    </form>
                    <form action="/admin/reject/<%= u.id %>" method="POST" style="display:inline">
                      <button type="submit" class="btn btn-reject btn-xs">✕ Reddet</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- ── Approved Users ── -->
    <div class="admin-panel" id="tab-approved" role="tabpanel" hidden>
      <% if (approvedUsers.length === 0) { %>
        <div class="empty-state empty-state-sm">
          <div class="empty-icon">👥</div>
          <h3>Henüz onaylı kullanıcı yok</h3>
        </div>
      <% } else { %>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Ad Soyad</th>
                <th>E-posta</th>
                <th>Üniversite</th>
                <th>EB Dönemi</th>
                <th>Onay Tarihi</th>
                <th>İşlem</th>
              </tr>
            </thead>
            <tbody>
              <% approvedUsers.forEach(u => { %>
                <tr class="admin-row admin-row-approved">
                  <td class="user-name-cell">
                    <div class="user-avatar-mini user-avatar-approved"><%= u.name.charAt(0).toUpperCase() %></div>
                    <span><%= u.name %></span>
                  </td>
                  <td><a href="mailto:<%= u.email %>" class="table-link"><%= u.email %></a></td>
                  <td><%= u.school || '—' %></td>
                  <td><%= u.eb_year || '—' %></td>
                  <td class="date-cell">
                    <%= u.approved_at ? new Date(u.approved_at).toLocaleDateString('tr-TR', { day: '2-digit', month: 'short', year: 'numeric' }) : '—' %>
                  </td>
                  <td class="action-cell">
                    <a href="/admin/user/<%= u.id %>/edit" class="btn btn-outline btn-xs">✎ Düzenle</a>
                    <form action="/admin/reject/<%= u.id %>" method="POST" style="display:inline">
                      <button type="submit" class="btn btn-reject btn-xs">✕ İptal</button>
                    </form>
                    <form action="/admin/delete/<%= u.id %>" method="POST" style="display:inline" onsubmit="return confirm('Bu kullanıcıyı silmek istediğinizden emin misiniz?')">
                      <button type="submit" class="btn btn-delete btn-xs">🗑 Sil</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- ── Rejected Users ── -->
    <div class="admin-panel" id="tab-rejected" role="tabpanel" hidden>
      <% if (rejectedUsers.length === 0) { %>
        <div class="empty-state empty-state-sm">
          <div class="empty-icon">📋</div>
          <h3>Reddedilen kullanıcı yok</h3>
        </div>
      <% } else { %>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Ad Soyad</th>
                <th>E-posta</th>
                <th>Üniversite</th>
                <th>İşlem</th>
              </tr>
            </thead>
            <tbody>
              <% rejectedUsers.forEach(u => { %>
                <tr class="admin-row admin-row-rejected">
                  <td class="user-name-cell">
                    <div class="user-avatar-mini user-avatar-rejected"><%= u.name.charAt(0).toUpperCase() %></div>
                    <span><%= u.name %></span>
                  </td>
                  <td><%= u.email %></td>
                  <td><%= u.school || '—' %></td>
                  <td class="action-cell">
                    <a href="/admin/user/<%= u.id %>/edit" class="btn btn-outline btn-xs">✎ Düzenle</a>
                    <form action="/admin/reset/<%= u.id %>" method="POST" style="display:inline">
                      <button type="submit" class="btn btn-approve btn-xs">↺ Tekrar Değerlendir</button>
                    </form>
                    <form action="/admin/delete/<%= u.id %>" method="POST" style="display:inline" onsubmit="return confirm('Bu kullanıcıyı silmek istediğinizden emin misiniz?')">
                      <button type="submit" class="btn btn-delete btn-xs">🗑 Sil</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- ── Feedbacks (Geri Bildirimler) Panel ── -->
    <div class="admin-panel" id="tab-feedbacks" role="tabpanel" hidden>
      <% if (feedbacks.length === 0) { %>
        <div class="empty-state empty-state-sm">
          <div class="empty-icon">💬</div>
          <h3>Henüz geri bildirim gelmemiş</h3>
          <p>Kullanıcılar form doldurdukça burada listelenecek.</p>
        </div>
      <% } else { %>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Gönderen</th>
                <th>E-posta</th>
                <th>Mesaj / Geri Bildirim</th>
                <th>Tarih</th>
                <th>İşlem</th>
              </tr>
            </thead>
            <tbody>
              <% feedbacks.forEach(f => { %>
                <tr class="admin-row">
                  <td class="user-name-cell">
                    <div class="user-avatar-mini"><%= (f.user_name || f.name || 'G').charAt(0).toUpperCase() %></div>
                    <span><%= f.user_name || f.name || 'Ziyaretçi (Anonim)' %></span>
                  </td>
                  <td><%= f.user_email || f.email || '—' %></td>
                  <td style="max-width: 400px; white-space: normal; word-break: break-word; font-size: 0.875rem; line-height: 1.5; padding: 1rem;"><%= f.message %></td>
                  <td class="date-cell" style="font-size: 0.8rem; color: var(--text-muted);">
                    <%= new Date(f.created_at).toLocaleDateString('tr-TR', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                  </td>
                  <td class="action-cell">
                    <form action="/admin/feedback/delete/<%= f.id %>" method="POST" style="display:inline" onsubmit="return confirm('Bu geri bildirimi silmek istediğinizden emin misiniz?')">
                      <button type="submit" class="btn btn-delete btn-xs">🗑 Sil</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

  </div>
</section>

<%- include('../layout/footer') %>
