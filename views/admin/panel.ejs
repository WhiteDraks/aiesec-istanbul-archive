<%- include('../layout/header', { currentPage: 'admin' }) %>

<section class="page-hero page-hero-sm page-hero-admin">
  <div class="page-hero-bg"></div>
  <div class="container">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
      <div>
        <h1 class="page-hero-title">Admin Paneli</h1>
        <p class="page-hero-sub">Alumni Archive Yönetimi</p>
      </div>
      <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
        <button onclick="openDigestModal()" class="btn btn-outline" style="border-color: rgba(245, 158, 11, 0.4); color: #f59e0b; background: rgba(245, 158, 11, 0.05);">📰 Bülten Gönder</button>
        <a href="/admin/timeline" class="btn btn-outline" style="border-color: rgba(3, 126, 243, 0.4); color: #037ef3; background: rgba(3, 126, 243, 0.05);">⏳ Zaman Tüneli</a>
        <a href="/admin/archive" class="btn btn-outline" style="border-color: rgba(168, 85, 247, 0.4); color: #a855f7; background: rgba(168, 85, 247, 0.05);">📁 Belge Arşivi</a>
        <a href="/admin/settings" class="btn btn-outline">⚙ Site Ayarları</a>
        <a href="/admin/eb" class="btn btn-primary">EB Takımları</a>
      </div>
    </div>
  </div>
</section>

<section class="section section-admin">
  <div class="container">

    <!-- Stats Row -->
    <div class="admin-stats" style="grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));">
      <div class="admin-stat admin-stat-pending">
        <span class="admin-stat-num"><%= stats.pending %></span>
        <span class="admin-stat-label">Bekleyen</span>
      </div>
      <div class="admin-stat admin-stat-approved">
        <span class="admin-stat-num"><%= stats.approved %></span>
        <span class="admin-stat-label">Onaylı</span>
      </div>
      <div class="admin-stat admin-stat-rejected">
        <span class="admin-stat-num"><%= stats.rejected %></span>
        <span class="admin-stat-label">Reddedilen</span>
      </div>
      <div class="admin-stat admin-stat-total">
        <span class="admin-stat-num"><%= stats.total %></span>
        <span class="admin-stat-label">Toplam Üye</span>
      </div>
      <div class="admin-stat" style="border-color: rgba(3, 126, 243, 0.2); background: rgba(3, 126, 243, 0.02);">
        <span class="admin-stat-num" style="color: #037ef3;"><%= stats.jobs %></span>
        <span class="admin-stat-label">Kariyer İlanı</span>
      </div>
      <div class="admin-stat" style="border-color: rgba(245, 158, 11, 0.2); background: rgba(245, 158, 11, 0.02);">
        <span class="admin-stat-num" style="color: #f59e0b;"><%= stats.memories %></span>
        <span class="admin-stat-label">Dönem Anısı 📸</span>
      </div>
    </div>

    <!-- Tabs -->
    <div class="admin-tabs" role="tablist">
      <button class="admin-tab active" data-tab="pending" role="tab" aria-selected="true">
        Bekleyenler
        <% if (stats.pending > 0) { %><span class="tab-badge tab-badge-pending"><%= stats.pending %></span><% } %>
      </button>
      <button class="admin-tab" data-tab="approved" role="tab" aria-selected="false">
        Onaylılar
        <span class="tab-badge tab-badge-approved"><%= stats.approved %></span>
      </button>
      <button class="admin-tab" data-tab="rejected" role="tab" aria-selected="false">
        Reddedilenler
        <span class="tab-badge tab-badge-rejected"><%= stats.rejected %></span>
      </button>
      <button class="admin-tab" data-tab="feedbacks" role="tab" aria-selected="false">
        Geri Bildirimler 💬
        <% if (feedbacks.length > 0) { %><span class="tab-badge" style="background: var(--primary);"><%= feedbacks.length %></span><% } %>
      </button>
    </div>

    <!-- ── Pending Users ── -->
    <div class="admin-panel" id="tab-pending" role="tabpanel">
      <% if (pendingUsers.length === 0) { %>
        <div class="empty-state empty-state-sm">
          <div class="empty-icon">✅</div>
          <h3>Bekleyen kayıt yok</h3>
          <p>Tüm kayıtlar işlendi.</p>
        </div>
      <% } else { %>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Ad Soyad</th>
                <th>E-posta</th>
                <th>Üniversite</th>
                <th>EB Dönemi</th>
                <th>Kayıt Tarihi</th>
                <th>İşlem</th>
              </tr>
            </thead>
            <tbody>
              <% pendingUsers.forEach(u => { %>
                <tr class="admin-row">
                  <td class="user-name-cell">
                    <div class="user-avatar-mini"><%= u.name.charAt(0).toUpperCase() %></div>
                    <span><%= u.name %></span>
                  </td>
                  <td><a href="mailto:<%= u.email %>" class="table-link"><%= u.email %></a></td>
                  <td><%= u.school || '—' %></td>
                  <td><%= u.eb_year || '—' %></td>
                  <td class="date-cell">
                    <%= new Date(u.created_at).toLocaleDateString('tr-TR', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                  </td>
                  <td class="action-cell">
                    <a href="/admin/user/<%= u.id %>/edit" class="btn btn-outline btn-xs">✎ Düzenle</a>
                    <form action="/admin/approve/<%= u.id %>" method="POST" style="display:inline">
                      <button type="submit" class="btn btn-approve btn-xs">✓ Onayla</button>
                    </form>
                    <form action="/admin/reject/<%= u.id %>" method="POST" style="display:inline">
                      <button type="submit" class="btn btn-reject btn-xs">✕ Reddet</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- ── Approved Users ── -->
    <div class="admin-panel" id="tab-approved" role="tabpanel" hidden>
      <% if (approvedUsers.length === 0) { %>
        <div class="empty-state empty-state-sm">
          <div class="empty-icon">👥</div>
          <h3>Henüz onaylı kullanıcı yok</h3>
        </div>
      <% } else { %>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Ad Soyad</th>
                <th>E-posta</th>
                <th>Üniversite</th>
                <th>EB Dönemi</th>
                <th>Onay Tarihi</th>
                <th>İşlem</th>
              </tr>
            </thead>
            <tbody>
              <% approvedUsers.forEach(u => { %>
                <tr class="admin-row admin-row-approved">
                  <td class="user-name-cell">
                    <div class="user-avatar-mini user-avatar-approved"><%= u.name.charAt(0).toUpperCase() %></div>
                    <span><%= u.name %></span>
                  </td>
                  <td><a href="mailto:<%= u.email %>" class="table-link"><%= u.email %></a></td>
                  <td><%= u.school || '—' %></td>
                  <td><%= u.eb_year || '—' %></td>
                  <td class="date-cell">
                    <%= u.approved_at ? new Date(u.approved_at).toLocaleDateString('tr-TR', { day: '2-digit', month: 'short', year: 'numeric' }) : '—' %>
                  </td>
                  <td class="action-cell">
                    <a href="/admin/user/<%= u.id %>/edit" class="btn btn-outline btn-xs">✎ Düzenle</a>
                    <form action="/admin/reject/<%= u.id %>" method="POST" style="display:inline">
                      <button type="submit" class="btn btn-reject btn-xs">✕ İptal</button>
                    </form>
                    <form action="/admin/delete/<%= u.id %>" method="POST" style="display:inline" onsubmit="return confirm('Bu kullanıcıyı silmek istediğinizden emin misiniz?')">
                      <button type="submit" class="btn btn-delete btn-xs">🗑 Sil</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- ── Rejected Users ── -->
    <div class="admin-panel" id="tab-rejected" role="tabpanel" hidden>
      <% if (rejectedUsers.length === 0) { %>
        <div class="empty-state empty-state-sm">
          <div class="empty-icon">📋</div>
          <h3>Reddedilen kullanıcı yok</h3>
        </div>
      <% } else { %>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Ad Soyad</th>
                <th>E-posta</th>
                <th>Üniversite</th>
                <th>İşlem</th>
              </tr>
            </thead>
            <tbody>
              <% rejectedUsers.forEach(u => { %>
                <tr class="admin-row admin-row-rejected">
                  <td class="user-name-cell">
                    <div class="user-avatar-mini user-avatar-rejected"><%= u.name.charAt(0).toUpperCase() %></div>
                    <span><%= u.name %></span>
                  </td>
                  <td><%= u.email %></td>
                  <td><%= u.school || '—' %></td>
                  <td class="action-cell">
                    <a href="/admin/user/<%= u.id %>/edit" class="btn btn-outline btn-xs">✎ Düzenle</a>
                    <form action="/admin/reset/<%= u.id %>" method="POST" style="display:inline">
                      <button type="submit" class="btn btn-approve btn-xs">↺ Tekrar Değerlendir</button>
                    </form>
                    <form action="/admin/delete/<%= u.id %>" method="POST" style="display:inline" onsubmit="return confirm('Bu kullanıcıyı silmek istediğinizden emin misiniz?')">
                      <button type="submit" class="btn btn-delete btn-xs">🗑 Sil</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- ── Feedbacks (Geri Bildirimler) Panel ── -->
    <div class="admin-panel" id="tab-feedbacks" role="tabpanel" hidden>
      <% if (feedbacks.length === 0) { %>
        <div class="empty-state empty-state-sm">
          <div class="empty-icon">💬</div>
          <h3>Henüz geri bildirim gelmemiş</h3>
          <p>Kullanıcılar form doldurdukça burada listelenecek.</p>
        </div>
      <% } else { %>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Gönderen</th>
                <th>E-posta</th>
                <th>Mesaj / Geri Bildirim</th>
                <th>Tarih</th>
                <th>İşlem</th>
              </tr>
            </thead>
            <tbody>
              <% feedbacks.forEach(f => { %>
                <tr class="admin-row">
                  <td class="user-name-cell">
                    <div class="user-avatar-mini"><%= (f.user_name || f.name || 'G').charAt(0).toUpperCase() %></div>
                    <span><%= f.user_name || f.name || 'Ziyaretçi (Anonim)' %></span>
                  </td>
                  <td><%= f.user_email || f.email || '—' %></td>
                  <td style="max-width: 400px; white-space: normal; word-break: break-word; font-size: 0.875rem; line-height: 1.5; padding: 1rem;"><%= f.message %></td>
                  <td class="date-cell" style="font-size: 0.8rem; color: var(--text-muted);">
                    <%= new Date(f.created_at).toLocaleDateString('tr-TR', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                  </td>
                  <td class="action-cell">
                    <form action="/admin/feedback/delete/<%= f.id %>" method="POST" style="display:inline" onsubmit="return confirm('Bu geri bildirimi silmek istediğinizden emin misiniz?')">
                      <button type="submit" class="btn btn-delete btn-xs">🗑 Sil</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

  </div>
</section>

<!-- Digest (Bülten) Modal -->
<div id="digestModal" class="modal" style="display: none; position: fixed; z-index: 10000; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.6); backdrop-filter: blur(8px); align-items: center; justify-content: center;">
  <div class="modal-content" style="background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 2rem; max-width: 600px; width: 90%; box-shadow: 0 10px 40px rgba(0,0,0,0.5);">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border); padding-bottom: 1rem;">
      <h3 style="margin: 0; color: #fff; font-size: 1.25rem;">📰 Mezunlar Bülteni Gönder</h3>
      <span onclick="closeDigestModal()" style="cursor: pointer; color: var(--text-muted); font-size: 1.5rem; font-weight: bold;">&times;</span>
    </div>
    <form action="/admin/digest/trigger" method="POST" style="display: flex; flex-direction: column; gap: 1.25rem;">
      <div class="form-group">
        <label for="digest_subject" class="form-label">Bülten Konusu (E-posta Başlığı)</label>
        <input type="text" id="digest_subject" name="digest_subject" class="form-input" value="Alumni Archive Portalı - Haftalık Özet 📰" required placeholder="Bülten konusu...">
      </div>
      <div class="form-group">
        <label for="digest_message" class="form-label">📝 Giriş Mesajı / Duyuru <span style="font-weight:400; color: var(--text-muted);">(İsteğe bağlı — bültenin en üstüne eklenir)</span></label>
        <textarea id="digest_message" name="digest_message" class="form-input" rows="4" placeholder="Sevgili Mezunlarımız, bu haftaki özet bültenimizle karşınızdayız..."></textarea>
      </div>

      <!-- Ekstra Bölüm -->
      <div style="background: rgba(255,255,255,0.03); border: 1px dashed var(--border); border-radius: 10px; padding: 1.25rem;">
        <p style="margin: 0 0 1rem 0; font-size: 0.85rem; font-weight: 600; color: var(--text);">✨ Ekstra Bölüm <span style="font-weight:400; color: var(--text-muted);">(İsteğe bağlı — bültenin sonuna özel bir bölüm ekler)</span></p>
        <div class="form-group" style="margin-bottom: 0.75rem;">
          <label for="digest_extra_title" class="form-label">Bölüm Başlığı</label>
          <input type="text" id="digest_extra_title" name="digest_extra_title" class="form-input" placeholder="Örn: 🎉 Duyurular, 📌 Etkinlik Takvimi, 💬 Editörden...">
        </div>
        <div class="form-group" style="margin-bottom: 0;">
          <label for="digest_extra_content" class="form-label">Bölüm İçeriği</label>
          <textarea id="digest_extra_content" name="digest_extra_content" class="form-input" rows="5" placeholder="Bu bölüme istediğiniz bir metin, duyuru veya liste ekleyebilirsiniz..."></textarea>
        </div>
      </div>

      <!-- Hedef Kitle Seçimi -->
      <div class="form-group" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border); border-radius: 10px; padding: 1.25rem;">
        <label class="form-label" style="font-weight:600; margin-bottom: 0.75rem;">👥 Alıcı Hedef Kitlesi</label>
        <div style="display: flex; gap: 1.5rem; margin-bottom: 1rem;">
          <label style="display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.875rem;">
            <input type="radio" name="target_type" value="all" checked onchange="toggleTargetYears(this.value)"> Tüm Onaylı Üyeler
          </label>
          <label style="display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.875rem;">
            <input type="radio" name="target_type" value="specific_eb" onchange="toggleTargetYears(this.value)"> Belirli EB Dönemleri
          </label>
        </div>

        <!-- EB Dönem Seçimi (Gizli) -->
        <div id="target-years-selector" style="display: none; border-top: 1px solid var(--border); padding-top: 1rem; margin-top: 0.5rem;">
          <label class="form-label" style="font-size: 0.8rem; margin-bottom: 0.5rem;">Gönderilecek EB Dönemlerini Seçin:</label>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 0.5rem; max-height: 120px; overflow-y: auto; padding: 0.5rem; background: rgba(0,0,0,0.2); border-radius: 8px;">
            <% if (typeof ebTeams !== 'undefined' && ebTeams && ebTeams.length > 0) { %>
              <% ebTeams.forEach(team => { %>
                <label style="display: inline-flex; align-items: center; gap: 0.4rem; cursor: pointer; font-size: 0.8.rem; color: var(--text);">
                  <input type="checkbox" name="selected_years" value="<%= team.year %>"> <%= team.year %>
                </label>
              <% }) %>
            <% } else { %>
              <span style="font-size: 0.75rem; color: var(--text-muted);">Dönem listesi yükleniyor veya boş.</span>
            <% } %>
          </div>
        </div>
      </div>

      <p class="form-hint" style="margin: 0; font-size: 0.8rem; color: var(--text-muted);">
        * Bülten Resend e-posta altyapısı üzerinden gönderilecektir. Son 7 günde eklenen yeni mezunlar, iş ilanları ve dönem anıları şablona otomatik olarak eklenir.
      </p>
      <div style="display: flex; justify-content: flex-end; gap: 0.75rem; margin-top: 1rem;">
        <button type="button" onclick="closeDigestModal()" class="btn btn-outline">İptal</button>
        <button type="submit" class="btn btn-primary">Bülteni Gönder</button>
      </div>
    </form>
  </div>
</div>

<script>
function openDigestModal() {
  document.getElementById('digestModal').style.display = 'flex';
}
function closeDigestModal() {
  document.getElementById('digestModal').style.display = 'none';
}
function toggleTargetYears(value) {
  const selector = document.getElementById('target-years-selector');
  if (value === 'specific_eb') {
    selector.style.display = 'block';
  } else {
    selector.style.display = 'none';
  }
}
// ensure modal is hidden by default on load
document.addEventListener('DOMContentLoaded', () => {
  closeDigestModal();
});
</script>

<%- include('../layout/footer') %>
