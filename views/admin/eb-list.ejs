<%- include('../layout/header') %>

<section class="page-hero page-hero-sm page-hero-admin">
  <div class="page-hero-bg"></div>
  <div class="container">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; border: none; padding: 0; background: none;">
      <div>
        <div class="breadcrumb">
          <a href="/admin">Admin Paneli</a>
          <span>›</span>
          <span>EB Yönetimi</span>
        </div>
        <h1 class="page-hero-title" style="margin-top: 0.5rem;">EB Yönetimi</h1>
        <p class="page-hero-sub">EB takımlarını, başarılarını ve fotoğraflarını yönetin.</p>
      </div>
      <a href="/admin" class="btn btn-outline btn-sm" style="border-color: rgba(255,255,255,0.4); color: #fff; background: rgba(4,13,26,0.6); backdrop-filter: blur(4px);">← Admin Paneline Dön</a>
    </div>
  </div>
</section>

<main class="container" style="margin-top: 3rem; margin-bottom: 5rem;">

  <div class="admin-grid" style="grid-template-columns: 1fr;">
    <div class="admin-card">
      <h3 class="admin-card-title">Mevcut EB Takımları</h3>
      <div class="table-responsive">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Dönem</th>
              <th>Takım Adı</th>
              <th>Üye Sayısı</th>
              <th>Durum</th>
              <th>Galeri Görseli</th>
              <th>İşlemler</th>
            </tr>
          </thead>
          <tbody>
            <% teams.forEach(team => { %>
              <tr>
                <td><strong><%= team.year %></strong></td>
                <td><%= team.meta?.title || `${team.year} Executive Board` %></td>
                <td><%= team.member_count %></td>
                <td>
                  <span class="status-badge <%= team.meta?.is_public ? 'status-approved' : 'status-pending' %>">
                    <%= team.meta?.is_public ? 'Yayında' : 'Gizli' %>
                  </span>
                </td>
                <td><%= team.meta?.gallery_images ? team.meta.gallery_images.length : 0 %> Fotoğraf</td>
                <td>
                  <div style="display: flex; gap: 0.75rem; align-items: center;">
                    <% if (team.meta) { %>
                      <a href="/admin/eb/<%= team.meta.id %>/edit" class="btn btn-sm btn-primary" style="display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.8rem; padding: 0.45rem 0.9rem; border-radius: 8px;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                        Düzenle
                      </a>
                    <% } else { %>
                      <a href="/admin/eb/year/<%= team.year %>/edit" class="btn btn-sm btn-primary" style="display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.8rem; padding: 0.45rem 0.9rem; border-radius: 8px;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                        Düzenle
                      </a>
                    <% } %>
                    <form action="/admin/eb/year/<%= encodeURIComponent(team.year) %>/delete" method="POST" style="display: inline; margin: 0;" onsubmit="return confirm('<%= team.year %> dönemini silmek istediğinizden emin misiniz? Bu işlem dönem metadatalarını, anılarını silecek ve üyelerin rol geçmişlerinden bu dönemi kaldıracaktır.')">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" class="btn btn-sm btn-danger" style="display: inline-flex; align-items: center; gap: 0.35rem; background: rgba(239, 68, 68, 0.08); border: 1px solid rgba(239, 68, 68, 0.3); color: #f87171; font-size: 0.8rem; padding: 0.45rem 0.9rem; border-radius: 8px; cursor: pointer; transition: all 0.2s;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                        Sil
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
            <% if (teams.length === 0) { %>
              <tr><td colspan="6" style="text-align: center;">Henüz hiçbir kullanıcı bir EB dönemine kayıtlı değil.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</main>

<%- include('../layout/footer') %>
