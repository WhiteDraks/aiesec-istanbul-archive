<%- include('../layout/header', { currentPage: 'admin' }) %>

<section class="page-hero page-hero-sm page-hero-admin">
  <div class="page-hero-bg"></div>
  <div class="container">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
      <div>
        <h1 class="page-hero-title">✏️ Kilometre Taşını Düzenle</h1>
        <p class="page-hero-sub"><%= milestone.year %>: <%= milestone.title %></p>
      </div>
      <div>
        <a href="/admin/timeline" class="btn btn-outline">◀ İptal ve Geri Dön</a>
      </div>
    </div>
  </div>
</section>

<section class="section section-admin">
  <div class="container">
    <div class="admin-panel" style="max-width: 800px; margin: 0 auto;">
      <form action="/admin/timeline/<%= milestone.id %>/edit" method="POST" enctype="multipart/form-data" class="admin-form">
        
        <input type="hidden" name="existing_image" value="<%= milestone.image_url %>">

        <div class="form-group">
          <label class="form-label">Yıl</label>
          <input type="number" name="year" class="form-input" required value="<%= milestone.year %>">
        </div>

        <div class="form-group">
          <label class="form-label">Başlık</label>
          <input type="text" name="title" class="form-input" required value="<%= milestone.title %>">
        </div>

        <div class="form-group">
          <label class="form-label">Açıklama</label>
          <textarea name="description" class="form-input" rows="4" required><%= milestone.description %></textarea>
        </div>

        <div class="form-group">
          <label class="form-label">Görsel Güncelle (Opsiyonel)</label>
          <% if (milestone.image_url) { %>
            <div style="margin-bottom: 1rem;">
              <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.5rem;">Mevcut Görsel:</p>
              <img src="<%= milestone.image_url %>" alt="Mevcut Görsel" style="max-width: 200px; border-radius: 8px; border: 1px solid var(--border);">
            </div>
          <% } %>
          <input type="file" name="image" class="form-input" accept="image/*">
          <p class="form-hint" style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.5rem;">Yeni bir görsel yüklerseniz, eski görselin yerini alacaktır.</p>
        </div>

        <div style="margin-top: 2rem;">
          <button type="submit" class="btn btn-primary btn-block">Değişiklikleri Kaydet</button>
        </div>
      </form>
    </div>
  </div>
</section>

<%- include('../layout/footer') %>
