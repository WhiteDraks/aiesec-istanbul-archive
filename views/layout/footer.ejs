<script src="/js/main.js"></script>

<!-- Global Image Cropper Modal -->
<div id="cropper-modal" style="display: none; position: fixed; inset: 0; background: rgba(9, 13, 22, 0.95); z-index: 99999; align-items: center; justify-content: center; padding: 1rem; backdrop-filter: blur(8px);">
  <div style="background: var(--surface); border: 1px solid var(--border); border-radius: 16px; max-width: 500px; width: 100%; overflow: hidden; display: flex; flex-direction: column; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
    <div style="padding: 1.25rem; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.02);">
      <h3 style="margin: 0; font-size: 1.1rem; font-weight: 600; color: #fff;">Görseli Düzenle ve Kırp ✂️</h3>
      <button type="button" onclick="closeCropperModal()" style="font-size: 1.5rem; color: var(--gray-400); line-height: 1; cursor: pointer;">&times;</button>
    </div>
    <div style="padding: 1rem; display: flex; align-items: center; justify-content: center; background: #05080f; height: 350px; position: relative;">
      <img id="cropper-image" style="max-width: 100%; max-height: 100%; display: block;">
    </div>
    <div style="padding: 1.25rem; border-top: 1px solid var(--border); display: flex; gap: 0.5rem; justify-content: flex-end; background: rgba(255,255,255,0.02);">
      <button type="button" class="btn btn-outline btn-sm" onclick="closeCropperModal()">Vazgeç</button>
      <button type="button" class="btn btn-primary btn-sm" onclick="saveCroppedImage()">Kırpmayı Tamamla</button>
    </div>
  </div>
</div>

<script>
let cropperInstance = null;
let currentFileInput = null;
let currentPreviewImg = null;
let currentRemoveInput = null;
let currentLabel = null;
let currentAspectRatio = 1;

function openCropper(event, fileInputId, previewImgId, removeInputId, labelId, aspectRatio = 1) {
  const file = event.target.files[0];
  if (!file) return;

  currentFileInput = document.getElementById(fileInputId);
  currentPreviewImg = document.getElementById(previewImgId);
  currentRemoveInput = document.getElementById(removeInputId);
  currentLabel = document.getElementById(labelId);
  currentAspectRatio = aspectRatio;

  const reader = new FileReader();
  reader.onload = function(e) {
    const cropperImg = document.getElementById('cropper-image');
    cropperImg.src = e.target.result;
    
    document.getElementById('cropper-modal').style.display = 'flex';
    
    if (cropperInstance) {
      cropperInstance.destroy();
    }
    
    cropperInstance = new Cropper(cropperImg, {
      aspectRatio: aspectRatio,
      viewMode: 1,
      autoCropArea: 0.9,
      background: false,
      responsive: true,
      restore: false,
    });
  };
  reader.readAsDataURL(file);
}

function closeCropperModal() {
  document.getElementById('cropper-modal').style.display = 'none';
  if (cropperInstance) {
    cropperInstance.destroy();
    cropperInstance = null;
  }
  if (currentFileInput) {
    currentFileInput.value = ''; // reset selection on cancel
  }
}

function saveCroppedImage() {
  if (!cropperInstance) return;

  // Calculate canvas dimensions dynamically to prevent image warp/stretching
  const canvasOpts = { imageSmoothingQuality: 'high' };
  if (currentAspectRatio) {
    if (currentAspectRatio === 1) {
      canvasOpts.width = 800;
      canvasOpts.height = 800;
    } else if (currentAspectRatio > 1) {
      canvasOpts.width = 1200;
      canvasOpts.height = Math.round(1200 / currentAspectRatio);
    } else {
      canvasOpts.height = 800;
      canvasOpts.width = Math.round(800 * currentAspectRatio);
    }
  } else {
    canvasOpts.width = 800;
    canvasOpts.height = 800;
  }

  const croppedCanvas = cropperInstance.getCroppedCanvas(canvasOpts);
  
  // 1. Get base64 representation of the cropped image
  const base64Data = croppedCanvas.toDataURL('image/jpeg', 0.92);

  // 2. Set base64 input on the form as fallback (crucial for mobile Safari/Chrome)
  if (currentFileInput && currentFileInput.form) {
    const form = currentFileInput.form;
    let hiddenInput = form.querySelector(`input[name="${currentFileInput.name}_base64"]`);
    if (!hiddenInput) {
      hiddenInput = document.createElement('input');
      hiddenInput.type = 'hidden';
      hiddenInput.name = `${currentFileInput.name}_base64`;
      form.appendChild(hiddenInput);
    }
    hiddenInput.value = base64Data;
  }

  // 3. Try to update files array using DataTransfer
  croppedCanvas.toBlob((blob) => {
    // Generate preview URL
    const croppedUrl = URL.createObjectURL(blob);
    if (currentPreviewImg) currentPreviewImg.src = croppedUrl;

    try {
      const croppedFile = new File([blob], 'cropped_image.jpg', { type: 'image/jpeg' });
      const dataTransfer = new DataTransfer();
      dataTransfer.items.add(croppedFile);
      if (currentFileInput) currentFileInput.files = dataTransfer.files;
    } catch (e) {
      console.warn('DataTransfer not supported by browser, falling back to base64 input fields:', e);
    }

    // Reset status fields
    if (currentRemoveInput) currentRemoveInput.value = 'false';
    if (currentLabel) {
      if (currentLabel.id === 'label-photo') {
        currentLabel.innerText = 'Fotoğrafı Değiştir';
        const removeBtn = document.getElementById('btn-remove-photo');
        if (removeBtn) removeBtn.style.display = 'inline-block';
      } else if (currentLabel.id === 'label-hero-bg') {
        currentLabel.innerText = 'Görseli Değiştir';
        const removeBtn = document.getElementById('btn-remove-hero-bg');
        if (removeBtn) removeBtn.style.display = 'inline-block';
      } else if (currentLabel.id === 'label-memory-photo') {
        currentLabel.innerText = 'Görseli Değiştir';
      }
    }

    // Hide Modal
    document.getElementById('cropper-modal').style.display = 'none';
    cropperInstance.destroy();
    cropperInstance = null;
  }, 'image/jpeg', 0.9);
}
</script>
</body>
