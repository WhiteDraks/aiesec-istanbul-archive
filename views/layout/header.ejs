<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="AIESEC İstanbul Executive Board Arşivi - Geçmiş EB dönemlerini, üyelerini ve hikayelerini keşfedin." />
  <title><%= title || 'AIESEC İstanbul Alumni Archive' %></title>

  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <!-- Main Stylesheet -->
  <link rel="stylesheet" href="/css/style.css" />

  <!-- Cropper.js for image resizing/cropping -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

  <!-- Dynamic Theme Settings -->
  <style>
    :root {
      <% if (siteSettings.theme_primary) { %>
        --blue-500: <%= siteSettings.theme_primary %>;
        --blue-600: <%= siteSettings.theme_primary %>dd;
        --blue-700: <%= siteSettings.theme_primary %>bb;
        --primary: <%= siteSettings.theme_primary %>;
        --primary-hover: <%= siteSettings.theme_primary %>ee;
      <% } %>
      <% if (siteSettings.theme_background) { %>
        --navy-900: <%= siteSettings.theme_background %>;
        --background: <%= siteSettings.theme_background %>;
      <% } %>
      <% if (siteSettings.theme_surface) { %>
        --navy-800: <%= siteSettings.theme_surface %>;
        --surface: <%= siteSettings.theme_surface %>;
      <% } %>
      <% if (siteSettings.theme_secondary) { %>
        --navy-700: <%= siteSettings.theme_secondary %>;
        --secondary: <%= siteSettings.theme_secondary %>;
      <% } %>
    }

    /* Modern Responsive Hover Dropdown */
    .nav-item-dropdown {
      position: relative;
    }
    .dropdown-menu {
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%) translateY(10px);
      background: rgba(17, 24, 39, 0.95);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      padding: 0.75rem;
      min-width: 200px;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
      opacity: 0;
      visibility: hidden;
      transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
      z-index: 1000;
    }
    .nav-item-dropdown:hover .dropdown-menu {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(0);
    }
    .dropdown-item {
      color: var(--gray-300) !important;
      padding: 0.6rem 1rem;
      border-radius: 8px;
      font-size: 0.9rem;
      font-weight: 500;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      white-space: nowrap;
    }
    .dropdown-item:hover {
      background: rgba(3, 126, 243, 0.15);
      color: #fff !important;
      padding-left: 1.25rem;
    }
    @media (max-width: 991px) {
      .dropdown-menu {
        position: static;
        transform: none;
        background: rgba(255, 255, 255, 0.02);
        border: none;
        box-shadow: none;
        padding: 0.5rem 0 0.5rem 1rem;
        opacity: 1;
        visibility: visible;
        display: flex;
      }
      .nav-item-dropdown:hover .dropdown-menu {
        transform: none;
      }
    }
  </style>

  <!-- Favicon -->
  <link class="favicon-icon" rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
</head>
<body>

<!-- ── Navigation ── -->
<nav class="navbar" id="navbar">
  <div class="container nav-inner">
    <!-- Logo -->
    <a href="/" class="nav-logo" id="nav-logo">
      <% if (siteSettings.site_logo_image) { %>
        <img src="<%= siteSettings.site_logo_image %>" alt="Logo" style="height: 48px; width: 48px; object-fit: contain; border-radius: 8px;" />
      <% } else { %>
        <div class="logo-emblem"><%= siteSettings.site_logo_emblem || 'A' %></div>
      <% } %>
      <span class="logo-text">
        <strong><%= siteSettings.site_logo_text || 'AIESEC' %></strong> <%= siteSettings.site_logo_sub || 'İstanbul' %>
        <small><%= siteSettings.site_title || 'Alumni Archive' %></small>
      </span>
    </a>

    <!-- Hamburger (mobile) -->
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Menüyü aç/kapat" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <!-- Nav Links -->
    <ul class="nav-links" id="nav-links">
      <li><a href="/" class="nav-link <%= typeof currentPage !== 'undefined' && currentPage === 'home' ? 'active' : '' %>">Ana Sayfa</a></li>
      <li><a href="/eb" class="nav-link <%= typeof currentPage !== 'undefined' && currentPage === 'eb' ? 'active' : '' %>">EB Takımları</a></li>

      <li><a href="/feedback" class="nav-link nav-link-highlight <%= typeof currentPage !== 'undefined' && currentPage === 'feedback' ? 'active' : '' %>" style="color: var(--primary) !important; font-weight: 600;">Geri Bildirim 💬</a></li>

      <% if (currentUser) { %>
        <% if (isApproved || isAdmin) { %>
          <li class="nav-item-dropdown">
            <a href="#" class="nav-link <%= typeof currentPage !== 'undefined' && ['alumni', 'jobs', 'events'].includes(currentPage) ? 'active' : '' %>" style="display: flex; align-items: center; gap: 0.25rem;">
              Topluluk 👥
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="margin-top: 2px;"><polyline points="6 9 12 15 18 9"/></svg>
            </a>
            <div class="dropdown-menu">
              <a href="/alumni" class="dropdown-item <%= typeof currentPage !== 'undefined' && currentPage === 'alumni' ? 'active' : '' %>">👥 Alumni Rehberi</a>
              <a href="/jobs" class="dropdown-item <%= typeof currentPage !== 'undefined' && currentPage === 'jobs' ? 'active' : '' %>">💼 Kariyer Panosu</a>
              <a href="/events" class="dropdown-item <%= typeof currentPage !== 'undefined' && currentPage === 'events' ? 'active' : '' %>">📅 Etkinlikler</a>
            </div>
          </li>
        <% } %>
        <li><a href="/profile" class="nav-link <%= typeof currentPage !== 'undefined' && currentPage === 'profile' ? 'active' : '' %>">Profilim</a></li>
        <% if (isAdmin) { %>
          <li><a href="/admin" class="nav-link nav-link-admin" id="nav-admin-link">
            <span class="admin-dot"></span>Admin
          </a></li>
        <% } %>
        <li>
          <a href="/auth/logout" class="btn btn-outline btn-sm">Çıkış (<%= currentUser.name.split(' ')[0] %>)</a>
        </li>
      <% } else { %>
        <li><a href="/auth/register" class="nav-link">Kayıt Ol</a></li>
        <li><a href="/auth/login" class="btn btn-primary btn-sm" id="nav-login-btn">Giriş Yap</a></li>
      <% } %>
    </ul>
  </div>
</nav>

<!-- ── Flash Messages ── -->
<% if (success && success.length > 0) { %>
  <div class="flash flash-success" role="alert">
    <span class="flash-icon">✓</span>
    <% success.forEach(msg => { %><span><%= msg %></span><% }) %>
    <button class="flash-close" onclick="this.parentElement.remove()">×</button>
  </div>
<% } %>
<% if (error && error.length > 0) { %>
  <div class="flash flash-error" role="alert">
    <span class="flash-icon">!</span>
    <% error.forEach(msg => { %><span><%= msg %></span><% }) %>
    <button class="flash-close" onclick="this.parentElement.remove()">×</button>
  </div>
<% } %>

<main id="main-content">
