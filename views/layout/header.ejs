    }
    .light-theme .nav-link {
      color: #334155 !important;
    }
    .light-theme .nav-link.active,
    .light-theme .nav-link:hover {
      color: var(--primary) !important;
    }
    @media (max-width: 768px) {
      .light-theme .nav-links {
        background: rgba(255, 255, 255, 0.98) !important;
        border-bottom: 1px solid rgba(15, 23, 42, 0.08) !important;
      }
    }
    .light-theme .dropdown-menu {
      background: rgba(255, 255, 255, 0.95) !important;
      border-color: rgba(15, 23, 42, 0.08) !important;
    }
    .light-theme .dropdown-item {
      color: #334155 !important;
    }
    .light-theme .dropdown-item:hover {
      background: rgba(3, 126, 243, 0.08) !important;
      color: var(--primary) !important;
    }
    .light-theme .page-hero-bg {
      background: linear-gradient(135deg, #f1f5f9, #e2e8f0) !important;
      border-bottom-color: rgba(15, 23, 42, 0.08) !important;
    }
    .light-theme .page-hero-title,
    .light-theme .page-hero-sub,
    .light-theme .feedback-form-container h3,
    .light-theme .feedback-form-container p,
    .light-theme .admin-card-title,
    .light-theme .admin-table th,
    .light-theme .admin-table td,
    .light-theme .logo-text,
    .light-theme .logo-text strong,
    .light-theme .logo-text small {
      color: #0f172a !important;
    }
    .light-theme .admin-table tr {
      border-bottom-color: rgba(15, 23, 42, 0.08) !important;
    }
    .light-theme .feedback-form-container {
      background: #ffffff !important;
      border-color: rgba(15, 23, 42, 0.08) !important;
    }
    .light-theme #theme-toggle-btn {
      color: #0f172a !important;
      border-color: rgba(15, 23, 42, 0.15) !important;
    }
    .theme-toggle-mobile-wrap {
      display: none;
      align-items: center;
      margin-right: 0.5rem;
    }
    @media (max-width: 991px) {
      .theme-toggle-mobile-wrap {
        display: flex !important;
      }
      #nav-links li:last-child {
        display: none !important;
      }
    }
  </style>

  <script>
    (function() {
      try {
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'light') {
          document.documentElement.classList.add('light-theme');
        }
      } catch (e) {
        console.warn('LocalStorage is blocked by security settings:', e);
      }
    })();

    function toggleTheme() {
      const isLight = document.documentElement.classList.toggle('light-theme');
      document.body.classList.toggle('light-theme', isLight);
      try {
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
      } catch (e) {
        console.warn('LocalStorage is blocked by security settings:', e);
      }
      document.querySelectorAll('.theme-toggle-icon-shared').forEach(icon => {
        icon.innerText = isLight ? '☀️' : '🌙';
      });
    }

    document.addEventListener('DOMContentLoaded', () => {
      let isLight = false;
      try {
        const savedTheme = localStorage.getItem('theme');
        isLight = savedTheme === 'light';
      } catch (e) {
        console.warn('LocalStorage is blocked by security settings:', e);
      }
      if (isLight) {
        document.body.classList.add('light-theme');
      }
      document.querySelectorAll('.theme-toggle-icon-shared').forEach(icon => {
        icon.innerText = isLight ? '☀️' : '🌙';
      });
    });
  </script>

  <!-- Favicon -->
  <link class="favicon-icon" rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
</head>
