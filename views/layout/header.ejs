  <!-- Dynamic Theme Settings -->
  <style>
    :root {
      <% const _s = (typeof siteSettings !== 'undefined' && siteSettings) ? siteSettings : {}; %>
      <% if (_s.theme_primary) { %>
        --blue-500: <%= _s.theme_primary %>;
        --blue-600: <%= _s.theme_primary %>dd;
        --blue-700: <%= _s.theme_primary %>bb;
        --primary: <%= _s.theme_primary %>;
        --primary-hover: <%= _s.theme_primary %>ee;
      <% } %>
      <% if (_s.theme_background) { %>
        --navy-900: <%= _s.theme_background %>;
        --background: <%= _s.theme_background %>;
      <% } %>
      <% if (_s.theme_surface) { %>
        --navy-800: <%= _s.theme_surface %>;
        --surface: <%= _s.theme_surface %>;
      <% } %>
      <% if (_s.theme_secondary) { %>
        --navy-700: <%= _s.theme_secondary %>;
        --secondary: <%= _s.theme_secondary %>;
      <% } %>
    }

    /* Modern Responsive Hover Dropdown */
    .nav-item-dropdown {
      position: relative;
    }
    .dropdown-menu .dropdown-item svg {
      color: var(--blue-sky, #00AEEF) !important;
    }
    .dropdown-menu {
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%) translateY(10px);
      background: rgba(17, 24, 39, 0.95);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      padding: 0.75rem;
      min-width: 200px;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
      opacity: 0;
      visibility: hidden;
      transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
      z-index: 1000;
    }
    .nav-item-dropdown:hover .dropdown-menu {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(0);
    }
    .dropdown-item {
      color: var(--gray-300) !important;
      padding: 0.6rem 1rem;
      border-radius: 8px;
      font-size: 0.9rem;
      font-weight: 500;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      white-space: nowrap;
    }
    .dropdown-item:hover {
      background: rgba(3, 126, 243, 0.15);
      color: #fff !important;
      padding-left: 1.25rem;
    }
    @media (max-width: 991px) {
      .dropdown-menu {
        display: none !important;
        opacity: 0;
        visibility: hidden;
        position: static;
        transform: none;
        background: rgba(255, 255, 255, 0.02);
        border: none;
        box-shadow: none;
        padding: 0.5rem 0 0.5rem 1rem;
        flex-direction: column;
        gap: 0.35rem;
      }
      .nav-item-dropdown.active-mobile .dropdown-menu {
        display: flex !important;
        opacity: 1;
        visibility: visible;
      }
    }

    /* Light Theme Global Override */
    /* Light Theme Global Override */
    .light-theme {
      --background: #f8fafc;
      --surface: #ffffff;
      --navy-900: #f8fafc;
      --navy-800: #ffffff;
      --navy-700: #f1f5f9;
      --navy-600: #e2e8f0;
      --text: #0f172a;
      --text-muted: #64748b;
      --text-lighter: #334155;
      --border: rgba(15, 23, 42, 0.08);
      --white: #0f172a;
      --gray-200: #1e293b;
      --gray-300: #334155;
      --gray-400: #475569;
      --gradient-hero: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 40%, #e2e8f0 100%);
      color: #0f172a;
    }

    /* Homepage Hero Light Mode */
    .light-theme .hero-title {
      color: #0f172a !important;
    }
    .light-theme .hero-title-gradient {
      background: linear-gradient(135deg, var(--primary, #037ef3) 0%, #00AEEF 100%) !important;
      -webkit-background-clip: text !important;
      background-clip: text !important;
      -webkit-text-fill-color: transparent !important;
    }
    .light-theme .hero-subtitle {
      color: #475569 !important;
    }
    .light-theme .hero-actions .btn-ghost {
      color: #0f172a !important;
      border-color: rgba(15, 23, 42, 0.25) !important;
    }
    .light-theme .hero-actions .btn-ghost:hover {
      background: rgba(15, 23, 42, 0.05) !important;
    }
    .light-theme .hero-stats {
      border-top-color: rgba(15, 23, 42, 0.08) !important;
    }
    .light-theme .stat-num {
      color: #0f172a !important;
    }
    .light-theme .stat-label {
      color: #64748b !important;
    }
    .light-theme .stat-divider {
      background: rgba(15, 23, 42, 0.1) !important;
    }

    /* About/Intro Section Light Mode */
    .light-theme .section-intro {
      background: rgba(15, 23, 42, 0.01) !important;
      border-top: 1px solid rgba(15, 23, 42, 0.06) !important;
      border-bottom: 1px solid rgba(15, 23, 42, 0.06) !important;
    }
    .light-theme .intro-card {
      background: #ffffff !important;
      border-color: rgba(15, 23, 42, 0.08) !important;
      box-shadow: 0 4px 15px rgba(0,0,0,0.02) !important;
    }
    .light-theme .intro-card-blue {
      background: rgba(3, 126, 243, 0.05) !important;
      border-color: rgba(3, 126, 243, 0.15) !important;
    }
    .light-theme .intro-card-navy {
      background: rgba(15, 23, 42, 0.02) !important;
      border-color: rgba(15, 23, 42, 0.06) !important;
    }
    .light-theme .intro-card h3 {
      color: #0f172a !important;
    }
    .light-theme .intro-card p {
      color: #475569 !important;
    }

    /* Card Components */
    .light-theme .profile-card,
    .light-theme .alumni-card,
    .light-theme .admin-card,
    .light-theme .feedback-widget-button,
    .light-theme .team-card {
      background: #ffffff !important;
      border-color: rgba(15, 23, 42, 0.08) !important;
      box-shadow: 0 4px 20px rgba(0,0,0,0.04) !important;
    }

    /* Jobs/Events Inner Separators & Badges */
    .light-theme .profile-card div,
    .light-theme .profile-card style {
      border-color: rgba(15, 23, 42, 0.08) !important;
    }
    .light-theme .profile-card [style*="border-bottom"],
    .light-theme .profile-card [style*="border-top"],
    .light-theme .profile-card [style*="border-left"],
    .light-theme .profile-card [style*="border-right"] {
      border-color: rgba(15, 23, 42, 0.08) !important;
    }
    .light-theme .profile-card [style*="background: rgba(255,255,255,0.03)"],
    .light-theme .profile-card [style*="background: rgba(255, 255, 255, 0.03)"],
    .light-theme .profile-card [style*="background:rgba(255,255,255,0.03)"] {
      background: rgba(15, 23, 42, 0.03) !important;
      border-color: rgba(15, 23, 42, 0.08) !important;
      color: #334155 !important;
    }
    
    /* General forms & interactive elements */
    .light-theme .form-input {
      background: #f8fafc !important;
      border-color: rgba(15, 23, 42, 0.12) !important;
      color: #0f172a !important;
    }
    .light-theme .form-input:focus {
      border-color: var(--primary) !important;
      background: #fff !important;
    }
    .light-theme .navbar {
