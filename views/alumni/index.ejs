<%- include('../layout/header') %>

<section class="page-hero page-hero-sm">
  <div class="page-hero-bg"></div>
  <div class="container">
    <div class="breadcrumb">
      <a href="/">Ana Sayfa</a>
      <span>›</span>
      <span>Alumni Rehberi</span>
    </div>
    <h1 class="page-hero-title">Mezunlar Rehberi</h1>
    <p class="page-hero-sub">AIESEC İstanbul mezunlarıyla bağlantı kurun, sektörlere göre filtreleyin.</p>
  </div>
</section>

<main class="container" style="margin-top: 3rem; margin-bottom: 5rem;">

  <!-- Gelişmiş Filtreleme & Arama Formu -->
  <form action="/alumni" method="GET" style="background: var(--surface); border: 1px solid var(--border); padding: 1.5rem; border-radius: 16px; margin-bottom: 2rem; display: flex; flex-direction: column; gap: 1rem;">
    <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 1rem; flex-wrap: wrap;">
      
      <!-- Text Search -->
      <div class="form-group" style="margin: 0;">
        <input type="text" name="query" class="form-input" placeholder="İsim, Şirket, Okul veya Departman Ara..." value="<%= activeQuery %>" style="padding: 0.65rem 1rem;">
      </div>

      <!-- Sector Filter -->
      <div class="form-group" style="margin: 0;">
        <select name="sector" class="form-input" style="padding: 0.65rem 1rem;">
          <option value="">Tüm Sektörler</option>
          <% sectors.forEach(sector => { %>
            <option value="<%= sector %>" <%= activeSector === sector ? 'selected' : '' %>><%= sector %></option>
          <% }) %>
        </select>
      </div>

      <!-- City Filter -->
      <div class="form-group" style="margin: 0;">
        <select name="city" class="form-input" style="padding: 0.65rem 1rem;">
          <option value="">Tüm Şehirler</option>
          <% cities.forEach(city => { %>
            <option value="<%= city %>" <%= activeCity === city ? 'selected' : '' %>><%= city %></option>
          <% }) %>
        </select>
      </div>

      <!-- Country Filter -->
      <div class="form-group" style="margin: 0;">
        <select name="country" class="form-input" style="padding: 0.65rem 1rem;">
          <option value="">Tüm Ülkeler</option>
          <% countries.forEach(country => { %>
            <option value="<%= country %>" <%= activeCountry === country ? 'selected' : '' %>><%= country %></option>
          <% }) %>
        </select>
      </div>

    </div>

    <!-- Bottom Filters (Mentorship + Buttons) -->
    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
      <label style="display: inline-flex; align-items: center; gap: 0.5rem; color: #fff; cursor: pointer; font-size: 0.9rem;">
        <input type="checkbox" name="is_mentor" value="true" <%= isMentorOnly ? 'checked' : '' %> style="width: 18px; height: 18px; border-radius: 4px; border: 1px solid var(--border); background: var(--surface); cursor: pointer;">
        🌟 Sadece Mentor Olmak İsteyenleri Göster
      </label>

      <div style="display: flex; gap: 0.5rem;">
        <a href="/alumni" class="btn btn-outline btn-sm">Temizle</a>
        <button type="submit" class="btn btn-primary btn-sm">Filtrele / Ara</button>
      </div>
    </div>
  </form>

  <% if (alumni.length === 0) { %>
    <div class="empty-state" style="background: var(--surface); border: 1px solid var(--border); padding: 4rem 2rem; border-radius: 16px; text-align: center;">
      <div class="empty-icon" style="font-size: 3rem; margin-bottom: 1rem;">👥</div>
      <h2>Kayıt Bulunamadı</h2>
      <p style="color: var(--text-muted); max-width: 400px; margin: 0 auto;">Arama kriterlerine uygun mezun kaydı bulunamadı. Lütfen filtreleri kontrol edin.</p>
    </div>
  <% } else { %>
    <div class="alumni-grid">
      <% alumni.forEach(person => { %>
        <div class="alumni-card" style="position: relative;">
          
          <!-- Mentor Badge -->
          <% if (person.is_mentor) { %>
            <span style="position: absolute; right: 1rem; top: 1rem; background: rgba(245, 158, 11, 0.15); border: 1px solid rgba(245, 158, 11, 0.4); color: #f59e0b; font-size: 0.7rem; padding: 0.2rem 0.5rem; border-radius: 20px; font-weight: 600; display: inline-flex; align-items: center; gap: 0.2rem; z-index: 10;">
              🌟 MENTOR
            </span>
          <% } %>

          <div class="alumni-header">
            <img src="<%= person.photo || '/images/default-avatar.svg' %>" alt="<%= person.name %>" class="alumni-avatar">
            <div class="alumni-title">
              <h3><%= person.name %></h3>
              <div style="display: flex; gap: 0.25rem; flex-wrap: wrap;">
                <span class="alumni-eb-year">EB <%= person.eb_year || 'Bilinmiyor' %></span>
                <% if (person.city) { %>
                  <span style="font-size: 0.75rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: var(--text-muted); padding: 0.15rem 0.4rem; border-radius: 4px;">
                    📍 <%= person.city %><%= person.country ? ', ' + person.country : '' %>
                  </span>
                <% } %>
              </div>
            </div>
          </div>
          
          <div class="alumni-body">
            <% if (person.sector) { %>
              <div class="alumni-info-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                <span><strong>Sektör:</strong> <%= person.sector %></span>
              </div>
            <% } %>

            <% if (person.workplaces) { %>
              <div class="alumni-info-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                <span><strong>İş Yerleri:</strong> <%= person.workplaces %></span>
              </div>
            <% } %>

            <% if (person.department || person.school) { %>
              <div class="alumni-info-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
                <span><strong>Eğitim:</strong> <%= person.school %> <%= person.department ? '- ' + person.department : '' %></span>
              </div>
            <% } %>

            <% if (person.aiesec_journey) { %>
              <div class="alumni-info-item journey-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
                <span><%= person.aiesec_journey %></span>
              </div>
            <% } %>

            <% if (person.is_mentor && person.mentorship_details) { %>
              <div class="alumni-info-item" style="background: rgba(245, 158, 11, 0.05); border-left: 3px solid #f59e0b; padding: 0.5rem; border-radius: 4px;">
                <span style="font-size: 0.85rem; color: #f59e0b; line-height: 1.4;">
                  💡 <strong>Mentorluk Odağı:</strong> <%= person.mentorship_details %>
                </span>
              </div>
            <% } %>
          </div>

          <div class="alumni-footer">
            <% if (person.linkedin) { %>
              <a href="<%= person.linkedin %>" target="_blank" class="alumni-link linkedin">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                LinkedIn
              </a>
            <% } %>
            <a href="mailto:<%= person.email %>" class="alumni-link email">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              İletişim
            </a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</main>

<style>
.alumni-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 2.5rem;
}
.filter-btn {
  padding: 0.5rem 1rem;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 20px;
  color: var(--text-muted);
  font-size: 0.875rem;
  text-decoration: none;
  transition: all 0.2s ease;
}
.filter-btn:hover {
  background: var(--hover);
  color: var(--text);
  border-color: var(--primary);
}
.filter-btn.active {
  background: var(--primary);
  color: white;
  border-color: var(--primary);
}

.alumni-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 1.5rem;
}

.alumni-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  display: flex;
  flex-direction: column;
}
.alumni-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 24px rgba(0,0,0,0.08);
}

.alumni-header {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.5rem;
  border-bottom: 1px solid var(--border);
}
.alumni-avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid var(--border);
}
.alumni-title h3 {
  margin: 0 0 0.25rem 0;
  font-size: 1.1rem;
  color: var(--text);
}
.alumni-eb-year {
  font-size: 0.875rem;
  color: var(--primary);
  background: rgba(3, 126, 243, 0.1);
  padding: 0.2rem 0.5rem;
  border-radius: 4px;
  font-weight: 500;
}

.alumni-body {
  padding: 1.5rem;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.875rem;
}
.alumni-info-item {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  font-size: 0.9rem;
  color: var(--text-muted);
  line-height: 1.5;
  word-break: break-word; /* Düzeltme: Uzun metinlerin taşmasını engeller */
}
.alumni-info-item svg {
  flex-shrink: 0;
  margin-top: 0.15rem;
  color: var(--text-lighter);
}
.alumni-info-item strong {
  color: var(--text);
  font-weight: 500;
}
.journey-item {
  margin-top: 0.5rem;
  padding-top: 0.5rem;
  border-top: 1px dashed var(--border);
  font-style: italic;
}

.alumni-footer {
  display: flex;
  border-top: 1px solid var(--border);
  background: var(--background);
}
.alumni-link {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 1rem;
  text-decoration: none;
  font-size: 0.9rem;
  font-weight: 500;
  transition: background 0.2s;
  color: var(--text-muted);
}
.alumni-link:hover {
  background: var(--hover);
  color: var(--primary);
}
.alumni-link:not(:last-child) {
  border-right: 1px solid var(--border);
}
</style>

<%- include('../layout/footer') %>
