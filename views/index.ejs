<%- include('./layout/header', { currentPage: 'home' }) %>

<!-- ── Hero Section ── -->
<section class="hero" id="hero" style="<%= siteSettings.hero_bg_image ? `background-image: linear-gradient(to bottom, rgba(4, 13, 26, 0.8), rgba(4, 13, 26, 0.95)), url('${siteSettings.hero_bg_image}'); background-size: cover; background-position: center; background-attachment: fixed;` : '' %>">
  <div class="hero-bg" style="<%= siteSettings.hero_bg_image ? 'display: none;' : '' %>">
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-orb hero-orb-3"></div>
    <div class="hero-grid"></div>
  </div>

  <div class="container hero-content">
    <div class="hero-badge">
      <span class="badge-dot"></span>
      <% if (currentUser) { %>İstanbul Alumni Archive<% } else { %>Alumni Archive<% } %>
    </div>

    <h1 class="hero-title">
      <%= siteSettings.hero_title || 'Alumni' %>
      <span class="hero-title-gradient"><%= siteSettings.hero_title_gradient || 'Executive Board' %></span>
      Archive
    </h1>

    <p class="hero-subtitle">
      <%= siteSettings.hero_subtitle || 'Geçmişin liderlerini, başarılarını ve hikayelerini bir araya getiren dijital arşiv platformu. Her dönem, bir neslin izlerini taşıyor.' %>
    </p>

    <div class="hero-actions">
      <a href="/eb" class="btn btn-primary btn-lg">
        <%= siteSettings.hero_cta_text || 'EB Takımlarını Keşfet' %>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <% if (!currentUser) { %>
        <a href="/auth/register" class="btn btn-ghost btn-lg">Topluluğa Katıl</a>
      <% } else { %>
        <a href="/eb/2026-2027" class="btn btn-ghost btn-lg">26.27 EB'yi Gör</a>
      <% } %>
    </div>

    <div class="hero-stats">
      <div class="stat-item">
        <span class="stat-num"><%= teams.length %>+</span>
        <span class="stat-label">EB Dönemi</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-num"><% if (currentUser) { %>AIESEC<% } else { %>Alumni<% } %></span>
        <span class="stat-label">İstanbul</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-num">Alumni</span>
        <span class="stat-label">Archive</span>
      </div>
    </div>
  </div>

  <div class="hero-scroll-indicator">
    <div class="scroll-arrow"></div>
  </div>
</section>

<!-- ── About / Intro Section ── -->
<section class="section section-intro">
  <div class="container">
    <div class="intro-grid">
      <div class="intro-text">
        <span class="section-label">Hakkımızda</span>
        <h2 class="section-title">Liderlik Mirası</h2>
        <p>
          İstanbul Alumni Archive, organizasyonun köklü tarihini yaşatmak amacıyla
          oluşturulmuş bir dijital arşivdir. Her Executive Board dönemi; üyelerin
          hikayeleri, başarıları ve katkılarıyla burada kalıcı hale getiriliyor.
        </p>
        <p>
          Bu platformda eski EB üyelerini, görevlerini, okul bilgilerini ve
          yolculuklarını bulabilirsiniz.
        </p>
        <a href="/eb" class="btn btn-primary">Tüm Dönemleri Gör</a>
      </div>
      <div class="intro-cards">
        <div class="intro-card intro-card-blue">
          <div class="intro-card-icon">🌍</div>
          <h3>Global Etki</h3>
          <p>Dünya genelinde 100+ ülkede faaliyet gösteren uluslararası liderlik platformunun İstanbul ayağı</p>
        </div>
        <div class="intro-card intro-card-navy">
          <div class="intro-card-icon">🎯</div>
          <h3>Liderlik Gelişimi</h3>
          <p>Her EB üyesi, pratik liderlik deneyimiyle organizasyonu şekillendirdi</p>
        </div>
        <div class="intro-card intro-card-light">
          <div class="intro-card-icon">🤝</div>
          <h3>Alumni Ağı</h3>
          <p>Güçlü alumni ağıyla birbirine bağlı profesyoneller topluluğu</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── EB Teams Section ── -->
<section class="section section-teams" id="teams">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Geçmiş Dönemler</span>
      <h2 class="section-title">Executive Board Takımları</h2>
      <p class="section-desc">
        İstanbul Alumni Archive'in her dönemde organizasyonu yöneten Executive Board takımlarını keşfedin.
      </p>
    </div>

    <% if (teams && teams.length > 0) { %>
      <div class="teams-grid">
        <% teams.forEach((team, i) => { %>
          <article class="team-card" style="--card-delay: <%= i * 0.1 %>s">
            <div class="team-card-cover">
              <img
                src="<%= team.cover_image || '/images/default-cover.jpg' %>"
                alt="<%= team.title %> kapak fotoğrafı"
                loading="<%= i < 2 ? 'eager' : 'lazy' %>"
              />
              <div class="team-card-overlay"></div>
              <div class="team-card-year"><%= team.year %></div>
            </div>
            <div class="team-card-body">
              <h3 class="team-card-title"><%= team.title %></h3>
              <p class="team-card-desc">
                <%= team.description ? team.description.substring(0, 100) + (team.description.length > 100 ? '...' : '') : 'İstanbul Alumni Archive Executive Board dönemi.' %>
              </p>
              <div class="team-card-footer">
                <% if (currentUser && isApproved) { %>
                  <a href="/eb/<%= encodeURIComponent(team.year) %>" class="btn btn-primary btn-sm">Detayları Gör</a>
                <% } else { %>
                  <a href="/auth/login" class="btn btn-outline btn-sm">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    Giriş Yap
                  </a>
                <% } %>
              </div>
            </div>
          </article>
        <% }) %>
      </div>

      <div class="section-cta">
        <a href="/eb" class="btn btn-outline btn-lg">Tüm Dönemleri Görüntüle</a>
      </div>
    <% } else { %>
      <div class="empty-state">
        <div class="empty-icon">📁</div>
        <h3>Henüz EB takımı eklenmemiş</h3>
        <p>Üyeler profillerinden dönemlerini girdikçe burada görünecek.</p>
      </div>
    <% } %>
  </div>
</section>

<!-- ── CTA Section ── -->
<% if (!currentUser) { %>
<section class="section section-cta-banner">
  <div class="container">
    <div class="cta-banner">
      <div class="cta-banner-bg">
        <div class="cta-orb cta-orb-1"></div>
        <div class="cta-orb cta-orb-2"></div>
      </div>
      <div class="cta-banner-content">
        <h2>Topluluğa Katıl</h2>
        <p>Kayıt ol, admin onayından sonra tüm EB detaylarına ve üye bilgilerine eriş.</p>
        <div class="cta-banner-actions">
          <a href="/auth/register" class="btn btn-white btn-lg">Hemen Kayıt Ol</a>
          <a href="/auth/login" class="btn btn-ghost-white btn-lg">Giriş Yap</a>
        </div>
      </div>
    </div>
  </div>
</section>
<% } %>

<%- include('./layout/footer') %>
