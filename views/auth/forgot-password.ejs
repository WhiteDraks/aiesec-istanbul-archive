<%- include('../layout/header') %>

<div class="auth-page">
  <div class="auth-container auth-container-login" style="max-width: 450px;">
    <!-- Form Panel -->
    <div class="auth-panel auth-panel-right" style="width: 100%; border-radius: 16px;">
      <div class="auth-form-wrap">
        <div class="auth-form-header">
          <h1>Şifremi Unuttum</h1>
          <p>E-posta adresinizi girerek şifre sıfırlama talebinde bulunun.</p>
        </div>

        <form action="/auth/forgot-password" method="POST" class="auth-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="form-group">
            <label for="email" class="form-label">E-posta Adresiniz</label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              placeholder="ornek@email.com"
              required
            />
          </div>

          <button type="submit" class="btn btn-primary btn-block">
            Sıfırlama Bağlantısı Gönder
          </button>
        </form>

        <p class="auth-switch" style="margin-top: 1.5rem; text-align: center;">
          <a href="/auth/login" style="color: var(--primary);">← Giriş Yap Sayfasına Dön</a>
        </p>
      </div>
    </div>
  </div>
</div>

<%- include('../layout/footer') %>
