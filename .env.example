# Environment Variables

# Vercel Postgres / Neon connection string
# Vercel dashboard'dan: Project → Storage → Postgres → .env.local'ı kopyala
# Neon dashboard'dan: Project → Connection string (pooled)
POSTGRES_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require

# Session secret - change this to a long random string
SESSION_SECRET=your_super_secret_session_key_here_change_this

# Port (for local dev)
PORT=3000

# Node environment
NODE_ENV=development
