# Environment Variables

# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/aiesec-istanbul?retryWrites=true&w=majority

# Session secret - change this to a long random string
SESSION_SECRET=your_super_secret_session_key_here_change_this

# Port (for local dev)
PORT=3000

# Node environment
NODE_ENV=development
